---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/docs", label: "Docs" },
  { href: "/examples", label: "Examples" },
  { href: "/playground", label: "Playground" },
];
---

<header
  data-header
  class="sticky top-0 z-40 bg-bg/80 backdrop-blur-xl border-b border-line transition-all"
>
  <div
    class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 h-14 flex items-center justify-between gap-4"
  >
    <a
      href="/"
      class="flex items-baseline text-ink font-semibold text-lg tracking-tight hover:text-brand transition-colors flex-shrink-0"
    >
      <span>wordink</span>
      <span class="cursor-blink"></span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-1 flex-1 justify-center">
      {
        navLinks.map(({ href, label }) => {
          const isActive =
            href === "/"
              ? currentPath === "/"
              : currentPath.startsWith(href);
          return (
            <a
              href={href}
              class:list={[
                "px-3 py-1.5 text-sm rounded-md transition-colors",
                isActive
                  ? "text-brand bg-brand/10"
                  : "text-mute hover:text-ink hover:bg-surface/40",
              ]}
            >
              {label}
            </a>
          );
        })
      }
    </nav>

    <!-- Desktop right cluster -->
    <div class="hidden md:flex items-center gap-2 flex-shrink-0">
      <button
        data-search-trigger
        class="flex items-center gap-2.5 text-sm text-mute-2 bg-surface/60 hover:bg-surface hover:text-mute border border-line rounded-md pl-2.5 pr-1.5 py-1 transition-colors"
        aria-label="Search"
      >
        <svg
          width="13"
          height="13"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <span class="font-mono text-xs">Search</span>
        <kbd
          class="font-mono text-[10px] px-1 py-0.5 rounded bg-bg/80 border border-line"
          >⌘K</kbd
        >
      </button>
      <a
        href="https://github.com/Word-Ink/Beta-V-1.0.0"
        target="_blank"
        rel="noopener"
        class="p-2 text-mute hover:text-ink rounded-md transition-colors"
        aria-label="GitHub"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
          ></path>
        </svg>
      </a>
    </div>

    <!-- Mobile right cluster -->
    <div class="flex md:hidden items-center gap-1 flex-shrink-0">
      <button
        data-search-trigger
        class="p-2 text-mute hover:text-ink rounded-md transition-colors"
        aria-label="Search"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </button>
      <button
        data-mobile-menu-trigger
        class="p-2 text-mute hover:text-ink rounded-md transition-colors"
        aria-label="Menu"
        aria-expanded="false"
      >
        <svg
          data-icon-open
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        >
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg
          data-icon-close
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          class="hidden"
        >
          <line x1="6" y1="6" x2="18" y2="18"></line>
          <line x1="6" y1="18" x2="18" y2="6"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <div
    data-mobile-menu
    class="md:hidden hidden border-t border-line bg-bg/95 backdrop-blur-xl"
  >
    <nav class="max-w-7xl mx-auto px-5 py-3 flex flex-col gap-1">
      {
        navLinks.map(({ href, label }) => {
          const isActive =
            href === "/"
              ? currentPath === "/"
              : currentPath.startsWith(href);
          return (
            <a
              href={href}
              class:list={[
                "px-3 py-2.5 text-base rounded-md",
                isActive
                  ? "text-brand bg-brand/10"
                  : "text-ink hover:bg-surface/50",
              ]}
            >
              {label}
            </a>
          );
        })
      }
      <a
        href="https://github.com/Word-Ink/Beta-V-1.0.0"
        target="_blank"
        rel="noopener"
        class="px-3 py-2.5 text-base rounded-md text-ink hover:bg-surface/50 flex items-center gap-2.5"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
          ></path>
        </svg>
        GitHub
      </a>
    </nav>
  </div>
</header>

<script>
  // Mobile menu toggle
  const trigger = document.querySelector("[data-mobile-menu-trigger]");
  const menu = document.querySelector("[data-mobile-menu]");
  const iconOpen = trigger?.querySelector("[data-icon-open]");
  const iconClose = trigger?.querySelector("[data-icon-close]");

  trigger?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    iconOpen?.classList.toggle("hidden", !isOpen);
    iconClose?.classList.toggle("hidden", isOpen);
    trigger.setAttribute("aria-expanded", String(!isOpen));
  });

  // Close mobile menu on navigation
  menu?.querySelectorAll("a").forEach((a) => {
    a.addEventListener("click", () => {
      menu.classList.add("hidden");
      iconOpen?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
      trigger?.setAttribute("aria-expanded", "false");
    });
  });

  // Header shadow on scroll
  const header = document.querySelector("[data-header]");
  const updateHeader = () => {
    if (!header) return;
    if (window.scrollY > 8) {
      header.classList.add("shadow-[0_1px_0_0_var(--color-line)]");
    } else {
      header.classList.remove("shadow-[0_1px_0_0_var(--color-line)]");
    }
  };
  window.addEventListener("scroll", updateHeader, { passive: true });

  // Cmd+K search
  const searchTriggers = document.querySelectorAll("[data-search-trigger]");
  searchTriggers.forEach((btn) =>
    btn.addEventListener("click", () => {
      window.dispatchEvent(new CustomEvent("wordink:open-search"));
    }),
  );

  window.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      window.dispatchEvent(new CustomEvent("wordink:open-search"));
    }
  });
</script>
