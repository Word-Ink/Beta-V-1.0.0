---
const columns = [
  {
    title: "Product",
    links: [
      { href: "/docs", label: "Docs" },
      { href: "/examples", label: "Examples" },
      { href: "/playground", label: "Playground" },
      { href: "/compare", label: "Compare" },
      { href: "/docs/plugins", label: "Roadmap" },
    ],
  },
  {
    title: "Get started",
    links: [
      { href: "/docs/installation", label: "Installation" },
      { href: "/docs/theming", label: "Theming" },
      { href: "/docs/editor", label: "API reference" },
      { href: "/docs/toolbar", label: "Toolbar primitives" },
    ],
  },
  {
    title: "Community",
    links: [
      {
        href: "https://github.com/Word-Ink/Beta-V-1.0.0",
        label: "GitHub",
        external: true,
      },
      {
        href: "https://twitter.com",
        label: "Twitter / X",
        external: true,
      },
      {
        href: "https://discord.com",
        label: "Discord",
        external: true,
      },
      {
        href: "/changelog",
        label: "Changelog",
      },
    ],
  },
];
---

<footer class="border-t border-line mt-32 bg-surface/20">
  <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-2 md:grid-cols-[1.4fr_repeat(3,1fr)] gap-10 mb-10">
      <!-- Brand column -->
      <div class="col-span-2 md:col-span-1">
        <a
          href="/"
          class="flex items-baseline text-ink font-semibold text-xl tracking-tight"
        >
          <span>wordink</span>
          <span class="cursor-blink"></span>
        </a>
        <p class="mt-3 text-sm text-mute leading-relaxed max-w-xs">
          The document editor that lives in your codebase. Word and Google
          Docs, but you own the source.
        </p>
        <div class="mt-5 flex items-center gap-3">
          <a
            href="https://github.com/Word-Ink/Beta-V-1.0.0"
            target="_blank"
            rel="noopener"
            class="p-2 text-mute-2 hover:text-ink rounded-md hover:bg-surface/60 transition-colors"
            aria-label="GitHub"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
              ></path></svg
            >
          </a>
          <a
            href="https://twitter.com"
            target="_blank"
            rel="noopener"
            class="p-2 text-mute-2 hover:text-ink rounded-md hover:bg-surface/60 transition-colors"
            aria-label="Twitter"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path></svg
            >
          </a>
          <a
            href="https://discord.com"
            target="_blank"
            rel="noopener"
            class="p-2 text-mute-2 hover:text-ink rounded-md hover:bg-surface/60 transition-colors"
            aria-label="Discord"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M20.317 4.37a19.79 19.79 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"
              ></path></svg
            >
          </a>
        </div>
      </div>

      {
        columns.map((col) => (
          <div>
            <p class="font-mono text-[10px] uppercase tracking-[0.14em] text-mute-2 mb-4">
              {col.title}
            </p>
            <ul class="space-y-2.5">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    target={link.external ? "_blank" : undefined}
                    rel={link.external ? "noopener" : undefined}
                    class="text-sm text-mute hover:text-ink transition-colors inline-flex items-center gap-1.5"
                  >
                    {link.label}
                    {link.external && (
                      <svg
                        width="10"
                        height="10"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        class="opacity-60"
                      >
                        <path d="M7 7h10v10" />
                        <path d="M7 17 17 7" />
                      </svg>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="pt-8 border-t border-line flex items-center justify-between flex-wrap gap-4"
    >
      <p class="text-xs text-mute-2 font-mono">
        © 2026 wordink · MIT licensed
      </p>
      <p class="text-xs font-mono text-mute-2 inline-flex items-center gap-2">
        <span>Crafted by</span>
        <a
          href="https://cybersquadinc.com"
          target="_blank"
          rel="noopener"
          class="group inline-flex items-center gap-1.5 text-ink font-medium hover:text-brand transition-colors"
        >
          <span
            class="w-1.5 h-1.5 rounded-full bg-brand transition-shadow group-hover:shadow-[0_0_8px_var(--color-brand)]"
          ></span>
          Cyber Squad Inc.
          <svg
            width="9"
            height="9"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            class="opacity-60 group-hover:opacity-100 group-hover:-translate-y-0.5 group-hover:translate-x-0.5 transition-all"
            aria-hidden="true"
          >
            <path d="M7 17 L17 7"></path>
            <path d="M7 7 L17 7 L17 17"></path>
          </svg>
        </a>
      </p>
    </div>
  </div>
</footer>
