---
interface Props {
  variant?: "full" | "compact";
  title?: string;
}

const { variant = "full", title = "Untitled document" } = Astro.props;
---

<div
  class="border border-line rounded-xl overflow-hidden bg-bg shadow-[0_24px_60px_-20px_rgba(0,0,0,0.5)]"
>
  <!-- Top chrome bar -->
  <div
    class="flex items-center gap-2 px-4 py-2.5 bg-surface/60 border-b border-line"
  >
    <div class="flex gap-1.5">
      <span class="w-2.5 h-2.5 rounded-full bg-line-2/80"></span>
      <span class="w-2.5 h-2.5 rounded-full bg-line-2/80"></span>
      <span class="w-2.5 h-2.5 rounded-full bg-line-2/80"></span>
    </div>
    <div
      class="ml-3 flex items-center gap-2 text-mute-2 font-mono text-xs flex-1 justify-center"
    >
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      <span>{title}</span>
    </div>
    <span class="text-[10px] font-mono text-mute-2">Auto-saving…</span>
  </div>

  <!-- Toolbar -->
  <div
    class="flex items-center gap-1 px-2 py-2 border-b border-line bg-surface/30 overflow-x-auto"
  >
    <button
      class="px-2.5 py-1.5 rounded text-xs bg-surface-2 border border-line text-mute hover:text-ink font-mono whitespace-nowrap flex items-center gap-1.5"
    >
      Heading 2
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
    </button>
    <button
      class="px-2.5 py-1.5 rounded text-xs bg-transparent text-mute hover:text-ink font-mono whitespace-nowrap flex items-center gap-1.5 border border-transparent"
    >
      16
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
    </button>
    <span class="w-px h-5 bg-line mx-0.5 flex-shrink-0"></span>

    <button
      class="w-7 h-7 rounded text-sm font-bold hover:bg-surface flex items-center justify-center flex-shrink-0"
      >B</button
    >
    <button
      class="w-7 h-7 rounded text-sm italic hover:bg-surface flex items-center justify-center flex-shrink-0 bg-brand/10 text-brand"
      >I</button
    >
    <button
      class="w-7 h-7 rounded text-sm underline hover:bg-surface flex items-center justify-center flex-shrink-0"
      >U</button
    >
    <button
      class="w-7 h-7 rounded text-sm hover:bg-surface flex items-center justify-center flex-shrink-0 line-through"
      >S</button
    >
    <button
      class="w-7 h-7 rounded text-xs font-mono hover:bg-surface flex items-center justify-center flex-shrink-0"
      >{"<>"}</button
    >
    <span class="w-px h-5 bg-line mx-0.5 flex-shrink-0"></span>

    <button
      class="w-7 h-7 rounded hover:bg-surface flex items-center justify-center flex-shrink-0"
      title="Text color"
    >
      <span class="w-3.5 h-3.5 rounded-sm bg-brand"></span>
    </button>
    <button
      class="w-7 h-7 rounded hover:bg-surface flex items-center justify-center flex-shrink-0"
      title="Highlight"
    >
      <span class="w-3.5 h-3.5 rounded-sm bg-[#f59e0b]"></span>
    </button>
    <span class="w-px h-5 bg-line mx-0.5 flex-shrink-0"></span>

    <button class="w-7 h-7 rounded text-mute hover:bg-surface flex items-center justify-center flex-shrink-0" title="Left">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="17" y1="10" x2="3" y2="10"/><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="14" x2="3" y2="14"/><line x1="17" y1="18" x2="3" y2="18"/></svg>
    </button>
    <button class="w-7 h-7 rounded text-mute hover:bg-surface flex items-center justify-center flex-shrink-0" title="Center">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="10" x2="6" y2="10"/><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="14" x2="3" y2="14"/><line x1="18" y1="18" x2="6" y2="18"/></svg>
    </button>
    <span class="w-px h-5 bg-line mx-0.5 flex-shrink-0"></span>

    <button class="w-7 h-7 rounded text-mute hover:bg-surface flex items-center justify-center flex-shrink-0" title="Bullet list">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="5" cy="6" r="1.2"/><line x1="9" y1="6" x2="20" y2="6"/><circle cx="5" cy="12" r="1.2"/><line x1="9" y1="12" x2="20" y2="12"/><circle cx="5" cy="18" r="1.2"/><line x1="9" y1="18" x2="20" y2="18"/></svg>
    </button>
    <button class="w-7 h-7 rounded text-mute hover:bg-surface flex items-center justify-center font-mono text-[10px] flex-shrink-0" title="Numbered">1.</button>
    <button class="w-7 h-7 rounded text-mute hover:bg-surface flex items-center justify-center flex-shrink-0" title="Quote">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1zm12 0c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.078c.937 0 .922 0 .922 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"/></svg>
    </button>
    <span class="w-px h-5 bg-line mx-0.5 flex-shrink-0"></span>

    <button class="w-7 h-7 rounded text-mute hover:bg-surface flex items-center justify-center flex-shrink-0" title="Link">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
    </button>
    <button class="w-7 h-7 rounded text-mute hover:bg-surface flex items-center justify-center flex-shrink-0" title="Image">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-5-5L5 21"/></svg>
    </button>
    <button class="w-7 h-7 rounded text-mute hover:bg-surface flex items-center justify-center flex-shrink-0" title="Table">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/></svg>
    </button>
    <span class="w-px h-5 bg-line mx-0.5 flex-shrink-0"></span>

    <button class="w-7 h-7 rounded text-mute hover:bg-surface flex items-center justify-center flex-shrink-0" title="Undo">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7v6h6"/><path d="M21 17a9 9 0 0 0-15-6.7L3 13"/></svg>
    </button>
    <button class="w-7 h-7 rounded text-mute hover:bg-surface flex items-center justify-center flex-shrink-0" title="Redo">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 7v6h-6"/><path d="M3 17a9 9 0 0 1 15-6.7L21 13"/></svg>
    </button>
  </div>

  <!-- Content -->
  <div class="px-8 md:px-12 py-10 max-w-3xl mx-auto">
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-ink mb-3 leading-tight">
      The case for owning your editor
    </h1>
    <p class="text-mute-2 text-xs font-mono mb-8">May 21, 2026 · Draft</p>

    <p class="text-ink leading-relaxed mb-4 text-[15.5px]">
      Most rich-text editors are <strong>libraries you depend on</strong>. wordink is
      a <em>folder you own</em>. The difference matters more than it sounds.
    </p>

    <p class="text-ink leading-relaxed mb-6 text-[15.5px]">
      When the editor ships as <code class="font-mono text-ink bg-surface border border-line px-1.5 py-0.5 rounded text-sm">source code, not abstractions</code>,
      you can change anything.
    </p>

    <h2 class="text-xl font-semibold tracking-tight text-ink mt-8 mb-4">
      What changes
    </h2>

    <ul class="space-y-2 mb-6 list-none">
      <li class="flex items-start gap-2 text-ink text-[15.5px] leading-relaxed">
        <span class="text-brand mt-2 flex-shrink-0">•</span>
        <span>Paste handling is yours. Tweak it for your domain.</span>
      </li>
      <li class="flex items-start gap-2 text-ink text-[15.5px] leading-relaxed">
        <span class="text-brand mt-2 flex-shrink-0">•</span>
        <span>Toolbar layout is yours. Use Shadcn, Radix, your own.</span>
      </li>
      <li class="flex items-start gap-2 text-ink text-[15.5px] leading-relaxed">
        <span class="text-brand mt-2 flex-shrink-0">•</span>
        <span>The dependency tree is just <em>react</em>.</span>
      </li>
    </ul>

    <blockquote
      class="border-l-2 border-brand pl-4 py-1 my-6 text-mute italic text-[15.5px]"
    >
      The best abstraction is the one you can delete.
    </blockquote>

    <p class="text-ink leading-relaxed mb-2 text-[15.5px]">
      That's wordink<span class="cursor-blink-soft"></span>
    </p>
  </div>

  <!-- Footer -->
  <div
    class="px-6 py-2.5 border-t border-line bg-surface/30 flex items-center justify-between text-xs font-mono text-mute-2"
  >
    <div class="flex items-center gap-4">
      <span>183 words · 1,120 characters</span>
      <span class="hidden sm:inline">Reading time · 1 min</span>
    </div>
    <span class="flex items-center gap-1.5">
      <span class="w-1.5 h-1.5 rounded-full bg-brand animate-pulse"></span>
      Saved
    </span>
  </div>
</div>
