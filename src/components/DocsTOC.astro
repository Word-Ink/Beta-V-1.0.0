---
// On-this-page TOC — populated client-side from headings in the article.
---

<aside class="docs-toc text-sm">
  <p
    class="font-mono text-[10px] uppercase tracking-[0.14em] text-mute-2 mb-3"
  >
    On this page
  </p>
  <ul data-toc-list class="space-y-1.5 border-l border-line">
    <li class="text-mute-2 text-xs italic pl-3">Loading…</li>
  </ul>
</aside>

<script>
  function slugify(text: string) {
    return text
      .toLowerCase()
      .trim()
      .replace(/[^\w\s-]/g, "")
      .replace(/\s+/g, "-")
      .replace(/-+/g, "-");
  }

  function init() {
    const article = document.querySelector("article .prose-wordink");
    const list = document.querySelector("[data-toc-list]");
    if (!article || !list) return;

    const headings = Array.from(
      article.querySelectorAll("h2, h3"),
    ) as HTMLElement[];

    if (headings.length === 0) {
      list.innerHTML =
        '<li class="text-mute-2 text-xs italic pl-3">No sections yet.</li>';
      return;
    }

    list.innerHTML = "";
    const items: { id: string; el: HTMLElement; anchor: HTMLAnchorElement }[] =
      [];

    headings.forEach((h) => {
      if (!h.id) {
        h.id = slugify(h.textContent || "");
      }
      const li = document.createElement("li");
      const a = document.createElement("a");
      a.href = `#${h.id}`;
      a.textContent = h.textContent || "";
      a.dataset.tocLink = h.id;
      const isH3 = h.tagName === "H3";
      a.className = `block py-1 transition-colors border-l-2 -ml-px ${
        isH3 ? "pl-6 text-xs" : "pl-3"
      } border-transparent text-mute hover:text-ink`;
      li.appendChild(a);
      list.appendChild(li);
      items.push({ id: h.id, el: h, anchor: a });
    });

    // Scroll spy
    let currentId: string | null = null;
    const setActive = (id: string | null) => {
      if (id === currentId) return;
      currentId = id;
      items.forEach(({ id: hid, anchor }) => {
        if (hid === id) {
          anchor.classList.remove("text-mute", "border-transparent");
          anchor.classList.add("text-brand", "border-brand");
        } else {
          anchor.classList.add("text-mute", "border-transparent");
          anchor.classList.remove("text-brand", "border-brand");
        }
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .map((e) => e.target as HTMLElement)
          .sort((a, b) => a.offsetTop - b.offsetTop);
        if (visible[0]) setActive(visible[0].id);
        else {
          // Fall back: find closest heading above scroll position
          const scrollTop = window.scrollY + 100;
          let active: string | null = null;
          for (const h of headings) {
            if (h.offsetTop <= scrollTop) active = h.id;
            else break;
          }
          if (active) setActive(active);
        }
      },
      { rootMargin: "-80px 0px -70% 0px" },
    );

    headings.forEach((h) => observer.observe(h));

    if (headings[0]) setActive(headings[0].id);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
