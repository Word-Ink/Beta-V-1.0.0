---
import { Code } from "astro:components";

interface Props {
  code: string;
  lang?: string;
  filename?: string;
  showDots?: boolean;
}

const { code, lang = "tsx", filename, showDots = false } = Astro.props;
const showBar = true;
const copyId = `cb-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="code-shell my-4 fade-up">
  {
    showBar && (
      <div class="code-shell-bar">
        {showDots && (
          <div class="code-shell-dots">
            <span class="code-shell-dot" />
            <span class="code-shell-dot" />
            <span class="code-shell-dot" />
          </div>
        )}
        {filename && <span class="code-shell-file">{filename}</span>}
        <button
          class="code-shell-copy"
          data-copy-button
          data-copy-target={copyId}
          aria-label="Copy code"
        >
          <svg
            width="11"
            height="11"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="9" y="9" width="13" height="13" rx="2" />
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
          </svg>
          <span data-copy-label>Copy</span>
        </button>
      </div>
    )
  }
  <div data-code-id={copyId} data-code={code}>
    <Code code={code} lang={lang as any} theme="vesper" />
  </div>
</div>

<script>
  document.querySelectorAll("[data-copy-button]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const targetId = btn.getAttribute("data-copy-target");
      const target = document.querySelector(`[data-code-id="${targetId}"]`);
      const code = target?.getAttribute("data-code") || "";
      try {
        await navigator.clipboard.writeText(code);
        btn.setAttribute("data-copied", "true");
        const label = btn.querySelector("[data-copy-label]");
        if (label) label.textContent = "Copied";
        setTimeout(() => {
          btn.removeAttribute("data-copied");
          if (label) label.textContent = "Copy";
        }, 1600);
      } catch (e) {
        // clipboard blocked — fail silently
      }
    });
  });
</script>
