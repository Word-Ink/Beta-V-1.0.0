---
const sections = [
  {
    title: "Docs",
    items: [
      { href: "/docs", label: "Introduction" },
      { href: "/docs/installation", label: "Installation" },
      { href: "/docs/theming", label: "Theming" },
      { href: "/docs/editor", label: "Editor API" },
      { href: "/docs/toolbar", label: "Toolbar primitives" },
      { href: "/docs/plugins", label: "Plugins" },
    ],
  },
  {
    title: "Examples",
    items: [
      { href: "/examples/blog-post", label: "Blog post editor" },
      { href: "/examples/email", label: "Email composer" },
      { href: "/examples/comment-box", label: "Comment box" },
      { href: "/examples/docs-editor", label: "Documentation editor" },
    ],
  },
  {
    title: "Pages",
    items: [
      { href: "/", label: "Home" },
      { href: "/playground", label: "Playground" },
      { href: "/compare", label: "Compare vs Google Docs / Word" },
      { href: "/changelog", label: "Changelog" },
    ],
  },
];
---

<div
  data-search-overlay
  class="fixed inset-0 z-50 hidden items-start justify-center pt-20 px-4 bg-bg/70 backdrop-blur-sm"
>
  <div
    data-search-modal
    class="w-full max-w-xl bg-surface border border-line-2 rounded-xl shadow-2xl overflow-hidden flex flex-col max-h-[70vh]"
  >
    <div class="flex items-center gap-3 px-4 py-3 border-b border-line">
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        class="text-mute-2 flex-shrink-0"
      >
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </svg>
      <input
        data-search-input
        type="text"
        placeholder="Search docs, examples, commands…"
        class="flex-1 bg-transparent text-ink placeholder:text-mute-2 outline-none text-sm font-sans"
      />
      <kbd
        class="font-mono text-[10px] px-1.5 py-0.5 rounded bg-surface-2 border border-line text-mute-2"
        >Esc</kbd
      >
    </div>

    <div data-search-results class="overflow-y-auto px-2 py-2 flex-1">
      {
        sections.map((section) => (
          <div data-section class="mb-3 last:mb-0">
            <p class="px-3 py-1.5 font-mono text-[10px] uppercase tracking-[0.12em] text-mute-2">
              {section.title}
            </p>
            <ul>
              {section.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    data-result-item
                    data-result-text={item.label}
                    class="flex items-center justify-between gap-3 px-3 py-2 rounded-md text-sm text-ink hover:bg-surface-2 group"
                  >
                    <span class="flex items-center gap-2.5">
                      <svg
                        width="13"
                        height="13"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        class="text-mute-2 group-hover:text-brand transition-colors"
                      >
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                        <polyline points="14 2 14 8 20 8" />
                      </svg>
                      {item.label}
                    </span>
                    <svg
                      width="12"
                      height="12"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      class="text-mute-2 opacity-0 group-hover:opacity-100 transition-opacity"
                    >
                      <path d="M5 12h14" />
                      <path d="m12 5 7 7-7 7" />
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
      <p
        data-search-empty
        class="hidden px-3 py-8 text-center text-sm text-mute-2"
      >
        No results.
      </p>
    </div>

    <div
      class="flex items-center justify-between px-4 py-2.5 border-t border-line bg-surface-2/50 text-[11px] font-mono text-mute-2"
    >
      <div class="flex items-center gap-3">
        <span class="flex items-center gap-1">
          <kbd class="px-1 py-0.5 rounded bg-bg border border-line">↑</kbd>
          <kbd class="px-1 py-0.5 rounded bg-bg border border-line">↓</kbd>
          to navigate
        </span>
        <span class="flex items-center gap-1">
          <kbd class="px-1 py-0.5 rounded bg-bg border border-line">⏎</kbd>
          to open
        </span>
      </div>
      <span>wordink search</span>
    </div>
  </div>
</div>

<script>
  const overlay = document.querySelector("[data-search-overlay]");
  const input = document.querySelector(
    "[data-search-input]",
  ) as HTMLInputElement | null;
  const results = document.querySelectorAll(
    "[data-result-item]",
  ) as NodeListOf<HTMLAnchorElement>;
  const sections = document.querySelectorAll("[data-section]");
  const emptyMsg = document.querySelector("[data-search-empty]");

  function openSearch() {
    overlay?.classList.remove("hidden");
    overlay?.classList.add("flex");
    setTimeout(() => input?.focus(), 10);
  }
  function closeSearch() {
    overlay?.classList.add("hidden");
    overlay?.classList.remove("flex");
    if (input) input.value = "";
    filterResults("");
  }

  window.addEventListener("wordink:open-search", openSearch);
  overlay?.addEventListener("click", (e) => {
    if (e.target === overlay) closeSearch();
  });
  window.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !overlay?.classList.contains("hidden")) {
      closeSearch();
    }
  });

  function filterResults(query: string) {
    const q = query.trim().toLowerCase();
    let visibleCount = 0;
    results.forEach((r) => {
      const text =
        r.getAttribute("data-result-text")?.toLowerCase() || "";
      const match = !q || text.includes(q);
      (r.parentElement as HTMLElement).style.display = match ? "" : "none";
      if (match) visibleCount++;
    });
    sections.forEach((sec) => {
      const visible = Array.from(
        sec.querySelectorAll("[data-result-item]"),
      ).some(
        (r) => ((r as HTMLElement).parentElement as HTMLElement).style.display !== "none",
      );
      (sec as HTMLElement).style.display = visible ? "" : "none";
    });
    if (emptyMsg) {
      (emptyMsg as HTMLElement).classList.toggle("hidden", visibleCount > 0);
    }
  }

  input?.addEventListener("input", () => filterResults(input.value));

  // Keyboard navigation
  let focusedIdx = -1;
  function getVisibleResults() {
    return Array.from(results).filter(
      (r) =>
        ((r.parentElement as HTMLElement).style.display !== "none") &&
        ((r.closest("[data-section]") as HTMLElement).style.display !== "none"),
    );
  }

  input?.addEventListener("keydown", (e) => {
    const visible = getVisibleResults();
    if (e.key === "ArrowDown") {
      e.preventDefault();
      focusedIdx = Math.min(focusedIdx + 1, visible.length - 1);
      visible[focusedIdx]?.focus();
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      focusedIdx = Math.max(focusedIdx - 1, 0);
      visible[focusedIdx]?.focus();
    } else if (e.key === "Enter" && visible[0]) {
      e.preventDefault();
      visible[0].click();
    }
  });
</script>
