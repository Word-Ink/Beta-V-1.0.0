---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SearchModal from "../components/SearchModal.astro";
import ScrollToTop from "../components/ScrollToTop.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "wordink — the document editor that lives in your codebase",
  description = "Aiming to do everything Google Docs and Microsoft Word can do — but as source code you copy into your repo. Headless, themeable, plugin-based.",
  ogImage = "/og.svg",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://wordink.dev").toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#15131c" />
    <meta name="color-scheme" content="dark" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Apply saved accent before first paint, no FOUC. -->
    <script is:inline>
      try {
        var saved = JSON.parse(localStorage.getItem("wordink:accent") || "null");
        if (saved && saved.value) {
          var root = document.documentElement;
          root.style.setProperty("--color-brand", saved.value);
          if (saved.deep) root.style.setProperty("--color-brand-deep", saved.deep);
          if (saved.soft) root.style.setProperty("--color-brand-soft", saved.soft);
        }
      } catch (e) {}
    </script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <SearchModal />
    <ScrollToTop />
  </body>
</html>
