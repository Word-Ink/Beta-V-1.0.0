---
import BaseLayout from "./BaseLayout.astro";
import DocsSidebar from "../components/DocsSidebar.astro";
import DocsTOC from "../components/DocsTOC.astro";
import ScrollProgress from "../components/ScrollProgress.astro";
import { getNeighbors } from "../lib/docs-nav";

interface Props {
  title: string;
  description?: string;
  section?: string;
}

const { title, description, section } = Astro.props;
const fullTitle = `${title} — wordink docs`;
const currentPath = Astro.url.pathname;
const { prev, next } = getNeighbors(currentPath);
---

<BaseLayout title={fullTitle} description={description}>
  <ScrollProgress />

  <div
    class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 grid md:grid-cols-[200px_minmax(0,1fr)] lg:grid-cols-[200px_minmax(0,1fr)_200px] gap-8 lg:gap-12 pt-10 md:pt-14 pb-24"
  >
    <aside
      class="hidden md:block md:sticky md:top-20 md:self-start md:max-h-[calc(100vh-6rem)] md:overflow-y-auto pb-8"
    >
      <DocsSidebar />
    </aside>

    <article class="min-w-0 docs-content fade-up">
      {
        section && (
          <p class="font-mono text-xs uppercase tracking-[0.14em] text-brand mb-3">
            {section}
          </p>
        )
      }
      <h1
        class="text-4xl md:text-5xl font-semibold tracking-tighter mb-6 leading-[1.05]"
      >
        {title}
      </h1>

      <div class="prose-wordink">
        <slot />
      </div>

      <nav class="mt-20 pt-8 border-t border-line grid grid-cols-2 gap-3">
        <div>
          {
            prev && (
              <a
                href={prev.href}
                class="block p-4 border border-line rounded-lg hover:bg-surface/50 hover:border-line-2 transition-colors group"
              >
                <p class="font-mono text-xs text-mute-2 mb-1 group-hover:text-mute flex items-center gap-1.5">
                  <span class="transition-transform group-hover:-translate-x-0.5">
                    ←
                  </span>{" "}
                  Previous
                </p>
                <p class="font-medium text-ink">{prev.label}</p>
              </a>
            )
          }
        </div>
        <div>
          {
            next && (
              <a
                href={next.href}
                class="block p-4 border border-line rounded-lg hover:bg-surface/50 hover:border-line-2 transition-colors text-right group"
              >
                <p class="font-mono text-xs text-mute-2 mb-1 group-hover:text-mute flex items-center gap-1.5 justify-end">
                  Next{" "}
                  <span class="transition-transform group-hover:translate-x-0.5">
                    →
                  </span>
                </p>
                <p class="font-medium text-ink">{next.label}</p>
              </a>
            )
          }
        </div>
      </nav>
    </article>

    <aside
      class="hidden lg:block lg:sticky lg:top-20 lg:self-start lg:max-h-[calc(100vh-6rem)] lg:overflow-y-auto pb-8"
    >
      <DocsTOC />
    </aside>
  </div>
</BaseLayout>

<style is:global>
  .prose-wordink {
    color: var(--color-mute);
    font-size: 1rem;
    line-height: 1.75;
    max-width: 70ch;
  }

  .prose-wordink > p {
    margin: 0 0 1.25rem;
  }

  .prose-wordink > p:last-child {
    margin-bottom: 0;
  }

  .prose-wordink h2 {
    color: var(--color-ink);
    font-size: 1.625rem;
    font-weight: 600;
    letter-spacing: -0.025em;
    margin: 3rem 0 1rem;
    line-height: 1.25;
    scroll-margin-top: 5rem;
  }

  .prose-wordink h3 {
    color: var(--color-ink);
    font-size: 1.15rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
    line-height: 1.4;
    scroll-margin-top: 5rem;
  }

  .prose-wordink a:not(.docs-button) {
    color: var(--color-brand);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    text-decoration-color: rgba(34, 211, 238, 0.4);
    transition: text-decoration-color 0.15s;
  }

  .prose-wordink a:not(.docs-button):hover {
    text-decoration-color: var(--color-brand);
  }

  .prose-wordink strong {
    color: var(--color-ink);
    font-weight: 600;
  }

  .prose-wordink em {
    color: var(--color-ink);
    font-style: italic;
  }

  .prose-wordink code:not(pre code) {
    color: var(--color-ink);
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    padding: 0.1em 0.4em;
    border-radius: 0.3rem;
    font-family: var(--font-mono);
    font-size: 0.86em;
    font-weight: 500;
  }

  .prose-wordink pre {
    background: var(--color-surface) !important;
    border: 1px solid var(--color-line);
    border-radius: 0.625rem;
    padding: 1rem 1.25rem !important;
    margin: 1.5rem 0;
    overflow-x: auto;
    font-size: 0.82rem;
    line-height: 1.65;
  }

  .prose-wordink pre code {
    font-family: var(--font-mono) !important;
    background: transparent !important;
    border: 0 !important;
    padding: 0 !important;
  }

  .prose-wordink ul {
    list-style: none;
    padding: 0;
    margin: 1rem 0 1.5rem;
  }

  .prose-wordink ul li {
    position: relative;
    padding-left: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .prose-wordink ul li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 4px;
    height: 4px;
    background: var(--color-brand);
    border-radius: 9999px;
  }

  .prose-wordink ol {
    list-style: decimal;
    padding-left: 1.5rem;
    margin: 1rem 0 1.5rem;
  }

  .prose-wordink ol li {
    margin-bottom: 0.5rem;
    padding-left: 0.25rem;
  }

  .prose-wordink ol li::marker {
    color: var(--color-mute-2);
    font-family: var(--font-mono);
    font-size: 0.875em;
  }

  .prose-wordink table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.875rem;
    border: 1px solid var(--color-line);
    border-radius: 0.625rem;
    overflow: hidden;
    display: block;
    overflow-x: auto;
  }

  .prose-wordink thead {
    background: var(--color-surface);
  }

  .prose-wordink th {
    text-align: left;
    padding: 0.75rem 1rem;
    font-weight: 500;
    color: var(--color-ink);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-bottom: 1px solid var(--color-line);
    white-space: nowrap;
  }

  .prose-wordink td {
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--color-line);
    vertical-align: top;
    color: var(--color-mute);
  }

  .prose-wordink td:first-child {
    color: var(--color-ink);
  }

  .prose-wordink tbody tr:last-child td {
    border-bottom: 0;
  }

  .prose-wordink hr {
    border: 0;
    border-top: 1px solid var(--color-line);
    margin: 2.5rem 0;
  }
</style>
