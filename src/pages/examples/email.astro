---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CodeBlock from "../../components/CodeBlock.astro";

const code = `import { useState } from "react";
import { useEditor, Editor, Toolbar } from "@/components/editor";

export function EmailComposer() {
  const [html, setHtml] = useState("");
  const editor = useEditor({
    value: html,
    onChange: setHtml,
    placeholder: "Write a message…",
    minRows: 8,
    paste: "rich", // preserve formatting from pasted content
  });

  return (
    <Editor instance={editor}>
      <Toolbar>
        <Toolbar.Group>
          <Toolbar.Button cmd="bold" />
          <Toolbar.Button cmd="italic" />
          <Toolbar.Button cmd="underline" />
        </Toolbar.Group>
        <Toolbar.Separator />
        <Toolbar.Button cmd="link" />
        <Toolbar.Separator />
        <Toolbar.Button cmd="insertUnorderedList" />
        <Toolbar.Button cmd="insertOrderedList" />
      </Toolbar>

      <Editor.Content />
    </Editor>
  );
}`;
---

<BaseLayout
  title="Email composer — wordink examples"
  description="A stripped-down editor template for transactional and marketing emails."
>
  <section class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8 pt-20 pb-8">
    <a
      href="/examples"
      class="text-mute hover:text-ink text-sm font-mono mb-6 inline-flex items-center gap-2 transition-colors"
    >
      ← Examples
    </a>
    <p class="font-mono text-xs uppercase tracking-[0.12em] text-mute mb-3">
      Template
    </p>
    <h1 class="text-5xl font-semibold tracking-tighter mb-4 leading-tight">
      Email composer
    </h1>
    <p class="text-lg text-mute max-w-2xl leading-relaxed">
      A minimal toolbar — bold, italic, link, lists. Output is clean HTML
      safe for email clients. No scripts, no exotic CSS.
    </p>
  </section>

  <section class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8 pb-12">
    <p class="font-mono text-xs uppercase tracking-[0.12em] text-mute mb-4">
      Preview
    </p>
    <div class="border border-line rounded-lg overflow-hidden bg-bg max-w-2xl mx-auto">
      <!-- Recipient row -->
      <div class="px-5 py-3 border-b border-line flex items-center gap-3 text-sm">
        <span class="text-mute-2 font-mono text-xs uppercase tracking-wider w-12">To</span>
        <span class="text-ink">team@research-goal.org</span>
      </div>
      <!-- Subject row -->
      <div class="px-5 py-3 border-b border-line flex items-center gap-3 text-sm">
        <span class="text-mute-2 font-mono text-xs uppercase tracking-wider w-12">Subject</span>
        <span class="text-ink">v0.1.0 is out — copy it into your repo</span>
      </div>

      <!-- Toolbar -->
      <div class="flex items-center gap-1 px-3 py-2 border-b border-line bg-surface/60">
        <button class="w-7 h-7 rounded text-sm font-bold hover:bg-surface flex items-center justify-center">B</button>
        <button class="w-7 h-7 rounded text-sm italic hover:bg-surface flex items-center justify-center">I</button>
        <button class="w-7 h-7 rounded text-sm underline hover:bg-surface flex items-center justify-center">U</button>
        <span class="w-px h-4 bg-line mx-1"></span>
        <button class="w-7 h-7 rounded text-mute hover:bg-surface flex items-center justify-center">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        </button>
        <span class="w-px h-4 bg-line mx-1"></span>
        <button class="w-7 h-7 rounded text-mute hover:bg-surface flex items-center justify-center">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="5" cy="6" r="1.2"/><line x1="9" y1="6" x2="20" y2="6"/><circle cx="5" cy="12" r="1.2"/><line x1="9" y1="12" x2="20" y2="12"/><circle cx="5" cy="18" r="1.2"/><line x1="9" y1="18" x2="20" y2="18"/></svg>
        </button>
      </div>

      <!-- Body -->
      <div class="p-5 min-h-[200px] text-[15px] leading-relaxed">
        <p class="text-ink mb-3">Hey team,</p>
        <p class="text-ink mb-3">
          The first usable build of <strong>wordink</strong> is live. You can grab it with:
        </p>
        <p class="text-ink mb-3 font-mono text-sm bg-surface border border-line rounded px-3 py-2">
          npx wordink add editor
        </p>
        <p class="text-ink mb-3">
          Take a look at the <a class="text-brand underline underline-offset-4 decoration-brand/40">docs</a> when you have a sec.
        </p>
        <p class="text-mute-2 text-sm font-mono">
          <span class="text-brand">|</span>
        </p>
      </div>

      <!-- Send -->
      <div class="px-5 py-3 border-t border-line bg-surface/30 flex items-center justify-between">
        <span class="text-xs font-mono text-mute-2">Draft saved</span>
        <button class="bg-brand text-bg font-semibold text-sm px-4 py-1.5 rounded">Send</button>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8 pb-24">
    <p class="font-mono text-xs uppercase tracking-[0.12em] text-mute mb-4">Code</p>
    <CodeBlock code={code} lang="tsx" filename="email-composer.tsx" />
  </section>
</BaseLayout>
