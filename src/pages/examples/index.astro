---
import BaseLayout from "../../layouts/BaseLayout.astro";

const examples = [
  {
    href: "/examples/blog-post",
    name: "Blog post editor",
    desc: "Full-featured editor for long-form writing — headings, blockquotes, images, code blocks, footnotes.",
    tags: ["Headings", "Lists", "Images", "Code", "Footnotes"],
  },
  {
    href: "/examples/email",
    name: "Email composer",
    desc: "Stripped-down toolbar for transactional and marketing emails. HTML output, no scripts, table-safe markup.",
    tags: ["Bold", "Italic", "Link", "List"],
  },
  {
    href: "/examples/comment-box",
    name: "Comment box",
    desc: "Tiny footprint comment input. Markdown shortcuts, mention support, submit on ⌘+Enter.",
    tags: ["Inline marks", "Mentions", "Compact"],
  },
  {
    href: "/examples/docs-editor",
    name: "Documentation editor",
    desc: "Optimised for technical writing — syntax-highlighted code blocks, callouts, anchored headings.",
    tags: ["Code", "Callouts", "TOC"],
  },
];
---

<BaseLayout
  title="Examples — wordink"
  description="Editor templates for blog posts, emails, comments, and documentation. Each is a single file you can copy."
>
  <section class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8 pt-24 pb-16">
    <p class="font-mono text-xs uppercase tracking-[0.12em] text-mute mb-3">
      Examples
    </p>
    <h1
      class="text-5xl md:text-6xl font-semibold tracking-tighter mb-4 leading-tight"
    >
      Templates.
    </h1>
    <p class="text-lg text-mute max-w-2xl leading-relaxed">
      Full editor templates for common use cases. Each one is a single file
      you can copy directly — the toolbar config, the styling, the
      integration.
    </p>
  </section>

  <section class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8 pb-24">
    <div
      class="grid md:grid-cols-2 gap-px bg-line border border-line rounded-lg overflow-hidden"
    >
      {
        examples.map(({ href, name, desc, tags }) => (
          <a
            href={href}
            class="block bg-bg p-8 hover:bg-surface/40 transition-colors group"
          >
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-xl font-semibold">{name}</h3>
              <span class="text-mute-2 group-hover:text-brand transition-colors text-lg">
                →
              </span>
            </div>
            <p class="text-sm text-mute leading-relaxed mb-5">{desc}</p>
            <div class="flex flex-wrap gap-1.5">
              {tags.map((tag) => (
                <span class="font-mono text-[10px] uppercase tracking-wider px-1.5 py-0.5 rounded bg-surface-2 border border-line text-mute-2">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
