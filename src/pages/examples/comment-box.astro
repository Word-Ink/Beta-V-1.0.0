---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CodeBlock from "../../components/CodeBlock.astro";

const code = `import { useState } from "react";
import { useEditor, Editor, Toolbar } from "@/components/editor";

export function CommentBox({ onSubmit }: { onSubmit: (html: string) => void }) {
  const [html, setHtml] = useState("");
  const editor = useEditor({
    value: html,
    onChange: setHtml,
    placeholder: "Write a comment…",
    minRows: 3,
    shortcuts: {
      "mod+enter": () => {
        if (html.trim()) onSubmit(html);
      },
    },
  });

  return (
    <Editor instance={editor}>
      <Toolbar size="sm">
        <Toolbar.Button cmd="bold" />
        <Toolbar.Button cmd="italic" />
        <Toolbar.Button cmd="code" />
        <Toolbar.Separator />
        <Toolbar.Button cmd="link" />
        <Toolbar.Button cmd="mention" />
      </Toolbar>

      <Editor.Content />

      <Editor.Footer>
        <button
          disabled={!html.trim()}
          onClick={() => onSubmit(html)}
        >
          Post comment
        </button>
      </Editor.Footer>
    </Editor>
  );
}`;
---

<BaseLayout
  title="Comment box — wordink examples"
  description="A compact comment input with mentions, markdown shortcuts, and submit-on-⌘+Enter."
>
  <section class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8 pt-20 pb-8">
    <a
      href="/examples"
      class="text-mute hover:text-ink text-sm font-mono mb-6 inline-flex items-center gap-2 transition-colors"
    >
      ← Examples
    </a>
    <p class="font-mono text-xs uppercase tracking-[0.12em] text-mute mb-3">
      Template
    </p>
    <h1 class="text-5xl font-semibold tracking-tighter mb-4 leading-tight">
      Comment box
    </h1>
    <p class="text-lg text-mute max-w-2xl leading-relaxed">
      Inline marks only. Markdown shortcuts (<code>**bold**</code>, <code>*italic*</code>).
      Mention support. Submits on <code>⌘+Enter</code>.
    </p>
  </section>

  <section class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8 pb-12">
    <p class="font-mono text-xs uppercase tracking-[0.12em] text-mute mb-4">
      Preview
    </p>
    <div class="border border-line rounded-lg overflow-hidden bg-bg max-w-2xl mx-auto">
      <!-- Thread context -->
      <div class="px-5 py-4 border-b border-line">
        <div class="flex items-start gap-3 mb-3">
          <div class="w-7 h-7 rounded-full bg-brand/20 border border-brand/40 flex items-center justify-center text-xs font-mono text-brand">
            RG
          </div>
          <div class="flex-1">
            <p class="text-sm">
              <span class="text-ink font-medium">research-goal</span>
              <span class="text-mute-2 ml-2">12 min ago</span>
            </p>
            <p class="text-mute text-sm mt-1 leading-relaxed">
              Does the link plugin support custom protocols? I want to allow
              <code class="text-ink bg-surface px-1 rounded text-xs">mailto:</code> and
              <code class="text-ink bg-surface px-1 rounded text-xs">tel:</code>.
            </p>
          </div>
        </div>
      </div>

      <!-- Comment input -->
      <div class="p-5">
        <div class="border border-line rounded-md bg-surface/40">
          <!-- Toolbar -->
          <div class="flex items-center gap-0.5 px-2 py-1.5 border-b border-line">
            <button class="w-6 h-6 rounded text-xs font-bold hover:bg-bg/50 flex items-center justify-center">B</button>
            <button class="w-6 h-6 rounded text-xs italic hover:bg-bg/50 flex items-center justify-center">I</button>
            <button class="w-6 h-6 rounded text-xs font-mono hover:bg-bg/50 flex items-center justify-center">{"<>"}</button>
            <span class="w-px h-3 bg-line mx-1"></span>
            <button class="w-6 h-6 rounded text-mute hover:bg-bg/50 flex items-center justify-center">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            </button>
            <button class="w-6 h-6 rounded text-mute hover:bg-bg/50 flex items-center justify-center font-mono text-xs">@</button>
          </div>
          <!-- Input -->
          <div class="px-3 py-2.5 text-sm text-ink leading-relaxed min-h-[80px]">
            Yeah, you can configure allowed protocols in the link plugin's options. Default is
            <span class="bg-brand/10 border border-brand/30 text-brand rounded px-1.5 py-0.5 font-mono text-xs">@research-goal</span>
            <span class="text-brand">|</span>
          </div>
        </div>
        <div class="flex items-center justify-between mt-3">
          <span class="text-xs font-mono text-mute-2">⌘ + Enter to send</span>
          <button class="bg-brand text-bg text-sm font-semibold px-3.5 py-1.5 rounded">
            Post comment
          </button>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8 pb-24">
    <p class="font-mono text-xs uppercase tracking-[0.12em] text-mute mb-4">Code</p>
    <CodeBlock code={code} lang="tsx" filename="comment-box.tsx" />
  </section>
</BaseLayout>
