---
import BaseLayout from "../layouts/BaseLayout.astro";

interface Cell {
  text: string;
  weight?: "strong" | "normal";
  tone?: "good" | "neutral" | "bad";
}
interface Row {
  feature: string;
  wordink: Cell;
  docs: Cell;
  word: Cell;
  libs: Cell;
}
interface Section {
  title: string;
  rows: Row[];
}

const sections: Section[] = [
  {
    title: "Distribution model",
    rows: [
      {
        feature: "Where the code lives",
        wordink: { text: "Your repo", weight: "strong", tone: "good" },
        docs: { text: "Google's servers", tone: "neutral" },
        word: { text: "Microsoft's binaries", tone: "neutral" },
        libs: { text: "node_modules", tone: "neutral" },
      },
      {
        feature: "Cost",
        wordink: { text: "Free · MIT", weight: "strong", tone: "good" },
        docs: { text: "Free with Google account", tone: "neutral" },
        word: { text: "$70/yr (M365)", tone: "neutral" },
        libs: { text: "Free (open source)", tone: "neutral" },
      },
      {
        feature: "Self-hostable",
        wordink: { text: "Just deploy your app", weight: "strong", tone: "good" },
        docs: { text: "No", tone: "bad" },
        word: { text: "On-prem licenses (enterprise)", tone: "neutral" },
        libs: { text: "Yes (as a dep)", tone: "neutral" },
      },
      {
        feature: "Source ownership",
        wordink: { text: "Yours", weight: "strong", tone: "good" },
        docs: { text: "Google", tone: "neutral" },
        word: { text: "Microsoft", tone: "neutral" },
        libs: { text: "External maintainers", tone: "neutral" },
      },
    ],
  },
  {
    title: "Text formatting",
    rows: [
      {
        feature: "Bold · Italic · Underline · Strike",
        wordink: { text: "Yes", weight: "strong", tone: "good" },
        docs: { text: "Yes", tone: "good" },
        word: { text: "Yes", tone: "good" },
        libs: { text: "Yes", tone: "good" },
      },
      {
        feature: "Font family · size",
        wordink: { text: "Yes", weight: "strong", tone: "good" },
        docs: { text: "Yes", tone: "good" },
        word: { text: "Yes", tone: "good" },
        libs: { text: "Plugin / extension", tone: "neutral" },
      },
      {
        feature: "Text color · highlight",
        wordink: { text: "Yes (HSV picker)", weight: "strong", tone: "good" },
        docs: { text: "Yes (basic)", tone: "good" },
        word: { text: "Yes (advanced)", tone: "good" },
        libs: { text: "Plugin", tone: "neutral" },
      },
      {
        feature: "Sub/superscript",
        wordink: { text: "Yes", weight: "strong", tone: "good" },
        docs: { text: "Yes", tone: "good" },
        word: { text: "Yes", tone: "good" },
        libs: { text: "Plugin", tone: "neutral" },
      },
    ],
  },
  {
    title: "Document structure",
    rows: [
      {
        feature: "Headings (H1 → H6)",
        wordink: { text: "Yes · all 6", weight: "strong", tone: "good" },
        docs: { text: "Yes · 1–6", tone: "good" },
        word: { text: "Yes · 1–9", tone: "good" },
        libs: { text: "Yes", tone: "good" },
      },
      {
        feature: "Bullet · numbered lists",
        wordink: { text: "Yes", weight: "strong", tone: "good" },
        docs: { text: "Yes", tone: "good" },
        word: { text: "Yes", tone: "good" },
        libs: { text: "Yes", tone: "good" },
      },
      {
        feature: "Code blocks",
        wordink: { text: "Yes", weight: "strong", tone: "good" },
        docs: { text: "Manual styling", tone: "neutral" },
        word: { text: "Manual styling", tone: "neutral" },
        libs: { text: "Yes (with highlighting)", tone: "good" },
      },
      {
        feature: "Tables",
        wordink: { text: "Insert (rows × cols)", tone: "neutral" },
        docs: { text: "Full editor", tone: "good" },
        word: { text: "Full editor", tone: "good" },
        libs: { text: "Plugin", tone: "neutral" },
      },
      {
        feature: "Footnotes · TOC · page numbers",
        wordink: { text: "Roadmap", tone: "bad" },
        docs: { text: "Yes", tone: "good" },
        word: { text: "Yes", tone: "good" },
        libs: { text: "Limited", tone: "neutral" },
      },
    ],
  },
  {
    title: "Inserts",
    rows: [
      {
        feature: "Images",
        wordink: { text: "URL · paste · drag-and-drop", weight: "strong", tone: "good" },
        docs: { text: "All sources", tone: "good" },
        word: { text: "All sources", tone: "good" },
        libs: { text: "Plugin", tone: "neutral" },
      },
      {
        feature: "Links (with popover)",
        wordink: { text: "Yes", weight: "strong", tone: "good" },
        docs: { text: "Yes", tone: "good" },
        word: { text: "Yes", tone: "good" },
        libs: { text: "Yes", tone: "good" },
      },
      {
        feature: "Math (LaTeX / KaTeX)",
        wordink: { text: "Roadmap", tone: "bad" },
        docs: { text: "Yes", tone: "good" },
        word: { text: "Yes", tone: "good" },
        libs: { text: "Plugin", tone: "neutral" },
      },
      {
        feature: "Mentions · @-tags",
        wordink: { text: "Roadmap", tone: "bad" },
        docs: { text: "Yes (within Google)", tone: "neutral" },
        word: { text: "Limited", tone: "neutral" },
        libs: { text: "Plugin", tone: "neutral" },
      },
    ],
  },
  {
    title: "Workflow",
    rows: [
      {
        feature: "Markdown shortcuts (**, *, #, -)",
        wordink: { text: "Yes (Notion-style)", weight: "strong", tone: "good" },
        docs: { text: "Limited (* for list)", tone: "neutral" },
        word: { text: "Limited (autocorrect)", tone: "neutral" },
        libs: { text: "Plugin", tone: "neutral" },
      },
      {
        feature: "Keyboard shortcuts",
        wordink: { text: "Yes (⌘B, ⌘K, …)", weight: "strong", tone: "good" },
        docs: { text: "Yes", tone: "good" },
        word: { text: "Yes (extensive)", tone: "good" },
        libs: { text: "Yes", tone: "good" },
      },
      {
        feature: "Undo · Redo",
        wordink: { text: "Browser-native", weight: "strong", tone: "good" },
        docs: { text: "Yes", tone: "good" },
        word: { text: "Yes", tone: "good" },
        libs: { text: "Yes", tone: "good" },
      },
      {
        feature: "Find & replace",
        wordink: { text: "Roadmap (browser ⌘F works)", tone: "neutral" },
        docs: { text: "Yes", tone: "good" },
        word: { text: "Yes (advanced)", tone: "good" },
        libs: { text: "Plugin", tone: "neutral" },
      },
      {
        feature: "Fullscreen / focus mode",
        wordink: { text: "Yes", weight: "strong", tone: "good" },
        docs: { text: "Limited", tone: "neutral" },
        word: { text: "Focus mode", tone: "good" },
        libs: { text: "DIY", tone: "neutral" },
      },
    ],
  },
  {
    title: "Export",
    rows: [
      {
        feature: "HTML",
        wordink: { text: "Native (copy / download)", weight: "strong", tone: "good" },
        docs: { text: "Yes", tone: "good" },
        word: { text: "Yes", tone: "good" },
        libs: { text: "Native or plugin", tone: "good" },
      },
      {
        feature: "PDF",
        wordink: { text: "Yes (print to PDF)", weight: "strong", tone: "good" },
        docs: { text: "Yes", tone: "good" },
        word: { text: "Yes", tone: "good" },
        libs: { text: "Plugin", tone: "neutral" },
      },
      {
        feature: "Markdown",
        wordink: { text: "Roadmap", tone: "bad" },
        docs: { text: "No (third-party only)", tone: "bad" },
        word: { text: "Add-in", tone: "neutral" },
        libs: { text: "Plugin", tone: "neutral" },
      },
      {
        feature: "DOCX",
        wordink: { text: "Roadmap", tone: "bad" },
        docs: { text: "Yes", tone: "good" },
        word: { text: "Native", tone: "good" },
        libs: { text: "Plugin", tone: "neutral" },
      },
    ],
  },
  {
    title: "Collaboration",
    rows: [
      {
        feature: "Real-time co-editing",
        wordink: { text: "Roadmap (Q1 2027)", tone: "bad" },
        docs: { text: "Yes (best-in-class)", tone: "good" },
        word: { text: "Yes (M365)", tone: "good" },
        libs: { text: "Yjs plugin (Tiptap)", tone: "good" },
      },
      {
        feature: "Comments · suggestions",
        wordink: { text: "Roadmap", tone: "bad" },
        docs: { text: "Yes", tone: "good" },
        word: { text: "Yes", tone: "good" },
        libs: { text: "Plugin", tone: "neutral" },
      },
      {
        feature: "Version history",
        wordink: { text: "Roadmap", tone: "bad" },
        docs: { text: "Yes", tone: "good" },
        word: { text: "AutoSave (M365)", tone: "good" },
        libs: { text: "DIY (git, snapshots)", tone: "neutral" },
      },
    ],
  },
  {
    title: "Theming & UI",
    rows: [
      {
        feature: "Custom toolbar UI",
        wordink: { text: "Yes (headless primitives)", weight: "strong", tone: "good" },
        docs: { text: "No", tone: "bad" },
        word: { text: "No", tone: "bad" },
        libs: { text: "Yes", tone: "good" },
      },
      {
        feature: "Theming (colors, fonts)",
        wordink: { text: "CSS variables · drop in tokens", weight: "strong", tone: "good" },
        docs: { text: "No", tone: "bad" },
        word: { text: "Themes (built-in)", tone: "neutral" },
        libs: { text: "CSS or plugin", tone: "neutral" },
      },
      {
        feature: "Mobile responsive",
        wordink: { text: "Yes", weight: "strong", tone: "good" },
        docs: { text: "Yes (app)", tone: "good" },
        word: { text: "Yes (app)", tone: "good" },
        libs: { text: "Yes", tone: "good" },
      },
    ],
  },
];

function toneClass(tone?: "good" | "neutral" | "bad") {
  if (tone === "good") return "text-ink";
  if (tone === "bad") return "text-mute-3";
  return "text-mute";
}
---

<BaseLayout
  title="How wordink compares — Google Docs · MS Word · Tiptap · Lexical"
  description="Detailed feature-by-feature comparison of wordink against Google Docs, Microsoft Word, and the popular editor libraries."
>
  <section class="max-w-5xl mx-auto px-5 sm:px-6 lg:px-8 pt-20 pb-12">
    <p class="font-mono text-xs uppercase tracking-[0.14em] text-brand mb-3">
      Compare
    </p>
    <h1 class="text-5xl md:text-6xl font-semibold tracking-tighter mb-5 leading-tight">
      A different shape of <span class="text-mute">solution.</span>
    </h1>
    <p class="text-lg text-mute max-w-2xl leading-relaxed mb-6">
      Tiptap and Lexical are excellent editor libraries — but they're
      dependencies. Google Docs and Word are excellent products — but you
      don't own them. wordink is a third option: a document editor as source
      code in your repo.
    </p>
    <p class="text-sm text-mute-2 font-mono">
      Updated 2026 · honest assessment · roadmap items marked clearly
    </p>
  </section>

  <section class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 pb-24">
    {
      sections.map((sec) => (
        <div class="mb-16 last:mb-0">
          <h2 class="font-mono text-[11px] uppercase tracking-[0.14em] text-mute mb-4">
            {sec.title}
          </h2>
          <div class="border border-line rounded-xl overflow-hidden overflow-x-auto bg-bg">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-line bg-surface/40">
                  <th class="text-left p-3.5 font-mono text-[10px] uppercase tracking-[0.14em] text-mute font-medium" />
                  <th class="text-left p-3.5 font-mono text-[10px] uppercase tracking-[0.14em] text-brand font-semibold border-l border-line">
                    wordink
                  </th>
                  <th class="text-left p-3.5 font-mono text-[10px] uppercase tracking-[0.14em] text-mute font-medium border-l border-line">
                    Google Docs
                  </th>
                  <th class="text-left p-3.5 font-mono text-[10px] uppercase tracking-[0.14em] text-mute font-medium border-l border-line">
                    MS Word
                  </th>
                  <th class="text-left p-3.5 font-mono text-[10px] uppercase tracking-[0.14em] text-mute font-medium border-l border-line">
                    Tiptap / Lexical
                  </th>
                </tr>
              </thead>
              <tbody>
                {sec.rows.map((row, i) => (
                  <tr
                    class:list={[
                      "border-b border-line last:border-b-0",
                      i % 2 === 1 && "bg-surface/15",
                    ]}
                  >
                    <td class="p-3.5 font-medium text-ink">{row.feature}</td>
                    <td class="p-3.5 border-l border-line">
                      <span
                        class:list={[
                          toneClass(row.wordink.tone),
                          row.wordink.weight === "strong" && "font-medium",
                        ]}
                      >
                        {row.wordink.text}
                      </span>
                    </td>
                    <td class="p-3.5 border-l border-line">
                      <span class={toneClass(row.docs.tone)}>{row.docs.text}</span>
                    </td>
                    <td class="p-3.5 border-l border-line">
                      <span class={toneClass(row.word.tone)}>{row.word.text}</span>
                    </td>
                    <td class="p-3.5 border-l border-line">
                      <span class={toneClass(row.libs.tone)}>{row.libs.text}</span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      ))
    }
  </section>

  <!-- CTA -->
  <section class="max-w-5xl mx-auto px-5 sm:px-6 lg:px-8 pb-24">
    <div
      class="border border-line rounded-2xl bg-gradient-to-b from-surface/60 to-bg p-10 md:p-14 text-center relative overflow-hidden"
    >
      <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(34,211,238,0.12),transparent_60%)] pointer-events-none"
      ></div>
      <div class="relative">
        <h2 class="text-3xl md:text-4xl font-semibold tracking-tight mb-4 leading-tight">
          Pick the right tool for the job.
        </h2>
        <p class="text-mute mb-8 max-w-xl mx-auto leading-relaxed text-lg">
          If you're building software that needs a document editor — give
          wordink a try. Five files, one command, source you own.
        </p>
        <div class="flex items-center justify-center gap-3 flex-wrap">
          <a
            href="/docs"
            class="cta-glow inline-flex items-center gap-2 bg-brand text-bg font-semibold px-5 py-3 rounded-md text-sm"
          >
            Read the docs →
          </a>
          <a
            href="/playground"
            class="inline-flex items-center gap-2 border border-line-2 text-ink px-5 py-3 rounded-md text-sm hover:bg-surface transition-colors"
          >
            Try the playground
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
