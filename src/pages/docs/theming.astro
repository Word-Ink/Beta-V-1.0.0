---
import DocsLayout from "../../layouts/DocsLayout.astro";
import CodeBlock from "../../components/CodeBlock.astro";

const customTheme = `:root {
  --editor-bg: #15131c;
  --editor-ink: #f4f1fa;
  --editor-mute: #a8a3b5;
  --editor-brand: #22d3ee;
  --editor-line: #322d3d;
  --editor-surface: #1d1a26;
  --editor-radius: 0.5rem;
}`;

const darkMode = `:root {
  --editor-bg: white;
  --editor-ink: #0f172a;
  /* …light tokens */
}

.dark {
  --editor-bg: #15131c;
  --editor-ink: #f4f1fa;
  /* …dark tokens */
}`;

const perInstance = `<div style={{ "--editor-brand": "#ec4899" }}>
  <Editor instance={editor}>...</Editor>
</div>`;
---

<DocsLayout
  title="Theming"
  section="Using it"
  description="The editor is themed entirely with CSS variables. Set tokens once — every surface follows."
>
  <p>
    The editor's appearance is controlled entirely by CSS variables. Set them
    in your global stylesheet and the editor adopts your design system.
  </p>

  <h2>Token reference</h2>

  <table>
    <thead>
      <tr>
        <th>Variable</th>
        <th>Purpose</th>
        <th>Default</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><code>--editor-bg</code></td>
        <td>Editor surface background</td>
        <td><code>white</code></td>
      </tr>
      <tr>
        <td><code>--editor-ink</code></td>
        <td>Body text color</td>
        <td><code>#0f172a</code></td>
      </tr>
      <tr>
        <td><code>--editor-mute</code></td>
        <td>Secondary text, placeholders</td>
        <td><code>#64748b</code></td>
      </tr>
      <tr>
        <td><code>--editor-brand</code></td>
        <td>Active toolbar state, focus rings, selection</td>
        <td><code>#2563eb</code></td>
      </tr>
      <tr>
        <td><code>--editor-line</code></td>
        <td>Borders and dividers</td>
        <td><code>#e2e8f0</code></td>
      </tr>
      <tr>
        <td><code>--editor-surface</code></td>
        <td>Toolbar and popover background</td>
        <td><code>#f8fafc</code></td>
      </tr>
      <tr>
        <td><code>--editor-font-sans</code></td>
        <td>Body font</td>
        <td>system stack</td>
      </tr>
      <tr>
        <td><code>--editor-font-mono</code></td>
        <td>Inline code font</td>
        <td>monospace stack</td>
      </tr>
      <tr>
        <td><code>--editor-radius</code></td>
        <td>Toolbar button radius</td>
        <td><code>0.375rem</code></td>
      </tr>
    </tbody>
  </table>

  <h2>A custom theme</h2>

  <CodeBlock code={customTheme} lang="css" />

  <p>
    Drop that into your <code>global.css</code> and the editor is now dark,
    cyan-accented, and matches the rest of this site.
  </p>

  <h2>Dark mode</h2>

  <p>
    The editor doesn't ship with a mode toggle — it just reads CSS variables.
    To toggle between light and dark themes, scope your tokens to a parent
    class:
  </p>

  <CodeBlock code={darkMode} lang="css" />

  <p>
    Wrap your editor in <code>&lt;div className="dark"&gt;</code> when dark mode
    is active. The editor will repaint to match.
  </p>

  <h2>Per-instance overrides</h2>

  <p>
    Need two editors with different themes on the same page? Set CSS variables
    on the parent element:
  </p>

  <CodeBlock code={perInstance} lang="tsx" />

  <h2>Next steps</h2>

  <ul>
    <li><a href="/docs/editor">Editor API</a> — what the editor instance exposes</li>
    <li><a href="/docs/toolbar">Toolbar primitives</a> — building custom toolbars</li>
  </ul>
</DocsLayout>
