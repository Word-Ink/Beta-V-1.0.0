---
import DocsLayout from "../../layouts/DocsLayout.astro";
import CodeBlock from "../../components/CodeBlock.astro";

const hookSignature = `const editor = useEditor({
  value: string,                  // controlled HTML
  onChange: (html: string) => void,
  placeholder?: string,
  minRows?: number,               // sets min-height
  autoFocus?: boolean,
  paste?: "plain" | "rich",       // default: "plain"
});`;

const instanceShape = `editor.ref                  // ref to the contentEditable element
editor.run(cmd, value?)     // dispatch a command
editor.is(cmd)              // is this command active for the selection?
editor.value(cmd)           // current value (e.g. fontSize → "16px")
editor.captureSelection()   // save current Range
editor.restoreSelection()   // restore previously captured Range
editor.focus()
editor.blur()`;

const editorComponent = `<Editor instance={editor}>
  <Toolbar>...</Toolbar>
  <Editor.Content />
  <Editor.Footer>
    {({ words, chars }) => <span>{words} words · {chars} chars</span>}
  </Editor.Footer>
</Editor>`;

const dispatching = `editor.run("bold");
editor.run("formatBlock", "h2");
editor.run("foreColor", "#22d3ee");
editor.run("link", { href: "https://example.com", newTab: true });`;
---

<DocsLayout
  title="Editor API"
  section="Using it"
  description="The full surface area of the core editor — the useEditor hook, the Editor component, commands and shortcuts."
>
  <p>
    The editor's behaviour lives in a single React hook: <code>useEditor</code
    >. The hook returns an <em>instance</em> object that you pass to the <code
      >&lt;Editor&gt;</code
    > shell.
  </p>

  <h2>useEditor()</h2>

  <CodeBlock code={hookSignature} lang="tsx" />

  <h3>The returned instance</h3>

  <CodeBlock code={instanceShape} lang="tsx" />

  <h2>The Editor component</h2>

  <CodeBlock code={editorComponent} lang="tsx" />

  <p>
    <code>&lt;Editor&gt;</code> is a slot-based shell. It doesn't render any chrome
    itself — you compose it from <code>&lt;Editor.Content&gt;</code> (the contentEditable
    surface), <code>&lt;Editor.Footer&gt;</code> (a render-prop area with live counts),
    and anything else you drop in.
  </p>

  <h2>Commands</h2>

  <p>
    Commands are the editor's verbs. Each one corresponds to a single user
    action — bold, insert link, change font size.
  </p>

  <table>
    <thead>
      <tr><th>Command</th><th>Value</th><th>Description</th></tr>
    </thead>
    <tbody>
      <tr><td><code>bold</code></td><td>—</td><td>Toggle bold on the selection</td></tr>
      <tr><td><code>italic</code></td><td>—</td><td>Toggle italic</td></tr>
      <tr><td><code>underline</code></td><td>—</td><td>Toggle underline</td></tr>
      <tr><td><code>strikethrough</code></td><td>—</td><td>Toggle strikethrough</td></tr>
      <tr><td><code>code</code></td><td>—</td><td>Toggle inline code</td></tr>
      <tr><td><code>formatBlock</code></td><td><code>h1 | h2 | h3 | p | blockquote | pre</code></td><td>Convert the block</td></tr>
      <tr><td><code>fontSize</code></td><td><code>12px</code> – <code>32px</code></td><td>Set inline font size</td></tr>
      <tr><td><code>fontFamily</code></td><td>CSS family value</td><td>Set inline font family</td></tr>
      <tr><td><code>foreColor</code></td><td>hex color</td><td>Set text color</td></tr>
      <tr><td><code>backColor</code></td><td>hex color</td><td>Set highlight color</td></tr>
      <tr><td><code>justifyLeft/Center/Right/Full</code></td><td>—</td><td>Alignment</td></tr>
      <tr><td><code>insertUnorderedList</code></td><td>—</td><td>Bullet list</td></tr>
      <tr><td><code>insertOrderedList</code></td><td>—</td><td>Numbered list</td></tr>
      <tr><td><code>indent</code> / <code>outdent</code></td><td>—</td><td>Indentation</td></tr>
      <tr><td><code>link</code></td><td><code>{`{ href, newTab }`}</code></td><td>Wrap selection in &lt;a&gt;</td></tr>
      <tr><td><code>unlink</code></td><td>—</td><td>Remove link</td></tr>
      <tr><td><code>image</code></td><td><code>{`{ src, alt? }`}</code></td><td>Insert image</td></tr>
      <tr><td><code>horizontalRule</code></td><td>—</td><td>Insert &lt;hr&gt;</td></tr>
      <tr><td><code>undo</code> / <code>redo</code></td><td>—</td><td>History</td></tr>
      <tr><td><code>removeFormat</code></td><td>—</td><td>Strip inline formatting</td></tr>
    </tbody>
  </table>

  <h3>Dispatching</h3>

  <CodeBlock code={dispatching} lang="tsx" />

  <h2>Keyboard shortcuts</h2>

  <p>
    The editor binds these by default. You can disable individual ones or add
    your own via the hook's <code>shortcuts</code> option.
  </p>

  <table>
    <thead>
      <tr><th>Keys</th><th>Command</th></tr>
    </thead>
    <tbody>
      <tr><td><code>⌘B</code> / <code>Ctrl+B</code></td><td>bold</td></tr>
      <tr><td><code>⌘I</code> / <code>Ctrl+I</code></td><td>italic</td></tr>
      <tr><td><code>⌘U</code> / <code>Ctrl+U</code></td><td>underline</td></tr>
      <tr><td><code>⌘K</code> / <code>Ctrl+K</code></td><td>link popover</td></tr>
      <tr><td><code>⌘Z</code> / <code>Ctrl+Z</code></td><td>undo</td></tr>
      <tr><td><code>⌘⇧Z</code> / <code>Ctrl+Y</code></td><td>redo</td></tr>
      <tr><td><code>⌘⇧7</code></td><td>numbered list</td></tr>
      <tr><td><code>⌘⇧8</code></td><td>bullet list</td></tr>
    </tbody>
  </table>

  <h2>Next steps</h2>

  <ul>
    <li><a href="/docs/toolbar">Toolbar primitives</a> — wire commands into your UI</li>
    <li><a href="/docs/plugins">Plugins</a> — extend the command set</li>
  </ul>
</DocsLayout>
