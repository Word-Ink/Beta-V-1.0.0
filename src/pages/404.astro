---
import BaseLayout from "../layouts/BaseLayout.astro";

const popular = [
  { href: "/docs", label: "Docs · Introduction" },
  { href: "/docs/installation", label: "Installation" },
  { href: "/examples", label: "Examples" },
  { href: "/playground", label: "Playground" },
];
---

<BaseLayout
  title="Page not found — wordink"
  description="That page doesn't exist."
>
  <section class="relative overflow-hidden min-h-[70vh] flex items-center">
    <div class="hero-grid"></div>
    <div class="hero-orb absolute -top-20 left-1/2 -translate-x-1/2 opacity-50"></div>

    <div
      class="relative max-w-3xl mx-auto px-5 sm:px-6 lg:px-8 py-20 text-center w-full"
    >
      <p
        class="font-mono text-xs uppercase tracking-[0.14em] text-brand mb-4"
      >
        Error · 404
      </p>
      <h1
        class="text-6xl sm:text-7xl md:text-8xl font-semibold tracking-tighter leading-[0.95] mb-6"
      >
        Page not <span class="text-mute">found.</span><span
          class="cursor-blink"></span>
      </h1>
      <p class="text-lg text-mute leading-relaxed mb-10 max-w-md mx-auto">
        That URL didn't match anything in your codebase. Or ours, in this
        case.
      </p>

      <div class="flex items-center justify-center gap-3 flex-wrap mb-12">
        <a
          href="/"
          class="cta-glow group inline-flex items-center gap-2 bg-brand text-bg font-semibold px-5 py-3 rounded-md text-sm"
        >
          <span class="transition-transform group-hover:-translate-x-0.5">←</span>
          Go home
        </a>
        <button
          data-search-trigger
          class="inline-flex items-center gap-2 border border-line-2 text-ink px-5 py-3 rounded-md text-sm hover:bg-surface transition-colors"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
          Search
          <kbd
            class="font-mono text-[10px] px-1 py-0.5 rounded bg-bg/80 border border-line ml-1"
            >⌘K</kbd
          >
        </button>
      </div>

      <div class="border-t border-line pt-8">
        <p
          class="font-mono text-[10px] uppercase tracking-[0.14em] text-mute-2 mb-4"
        >
          Or try one of these
        </p>
        <ul class="flex items-center justify-center gap-x-6 gap-y-2 flex-wrap">
          {
            popular.map((p) => (
              <li>
                <a
                  href={p.href}
                  class="text-sm text-mute hover:text-brand transition-colors inline-flex items-center gap-1.5"
                >
                  {p.label}
                  <span class="opacity-0 group-hover:opacity-100">→</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
