---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { PlaygroundIsland } from "../../components/PlaygroundIsland";
---

<BaseLayout
  title="Playground — wordink"
  description="Toggle plugins, swap palettes, change fonts — the editor and output panel update live in your browser."
>
  <section class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 pt-20 pb-8">
    <div class="flex items-start justify-between flex-wrap gap-4">
      <div>
        <p class="font-mono text-xs uppercase tracking-[0.14em] text-mute mb-3">
          Playground
        </p>
        <h1 class="text-5xl md:text-6xl font-semibold tracking-tighter mb-3 leading-tight">
          Try it. <span class="text-mute">For real.</span>
        </h1>
        <p class="text-lg text-mute max-w-2xl leading-relaxed">
          Real editor. Real output. Swap presets, change the accent, pick a
          font, toggle plugins — everything updates live.
        </p>
      </div>
      <div
        class="font-mono text-xs px-3 py-1.5 rounded-full bg-brand/10 border border-brand/30 text-brand inline-flex items-center gap-2"
      >
        <span
          class="w-1.5 h-1.5 rounded-full bg-brand shadow-[0_0_8px_currentColor]"
        ></span>
        Running in your browser
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 pb-24">
    <PlaygroundIsland client:only="react" />
    <p class="mt-6 text-center text-sm text-mute-2 font-mono">
      Output panel mirrors the editor in real time — copy HTML or JSON.
    </p>
  </section>
</BaseLayout>
