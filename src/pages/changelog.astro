---
import BaseLayout from "../layouts/BaseLayout.astro";

const releases = [
  {
    version: "0.1.0",
    date: "2026-05-21",
    tag: "Initial release",
    items: [
      "Core editor — contentEditable surface with selection capture, command dispatch, undo/redo, paste handling, keyboard shortcuts.",
      "Toolbar primitives — headless Button, Dropdown, ColorPicker, Group, Separator.",
      "Plugins shipped — Link (popover, target toggle), Image (URL), Color picker (HSV + hex + swatches), Format (bold / italic / underline / strike / code / sub / sup), Lists (bullet / numbered), Blocks (paragraph, H1–H3, blockquote, code block), Alignment, Indentation.",
      "Theming — every surface controlled by CSS variables.",
      "Documentation site shipped — homepage, docs, examples, playground.",
    ],
  },
];
---

<BaseLayout
  title="Changelog — wordink"
  description="Release notes for wordink."
>
  <section class="max-w-3xl mx-auto px-5 sm:px-6 lg:px-8 pt-20 pb-24">
    <p
      class="font-mono text-xs uppercase tracking-[0.14em] text-brand mb-3"
    >
      Changelog
    </p>
    <h1
      class="text-5xl md:text-6xl font-semibold tracking-tighter mb-4 leading-tight"
    >
      What changed.
    </h1>
    <p class="text-lg text-mute leading-relaxed mb-14 max-w-xl">
      Every shipped release. Versions follow <a
        href="https://semver.org"
        target="_blank"
        rel="noopener"
        class="text-brand underline decoration-brand/40 underline-offset-4"
        >semver</a
      > before 1.0 with breaking changes only on minor bumps.
    </p>

    <div class="space-y-12">
      {
        releases.map((r) => (
          <article class="relative pl-8 border-l border-line">
            <span class="absolute -left-[7px] top-2 w-3 h-3 rounded-full bg-brand shadow-[0_0_12px_var(--color-brand)]" />
            <div class="flex items-baseline gap-3 mb-2">
              <h2 class="text-2xl font-semibold tracking-tight">
                v{r.version}
              </h2>
              <span class="font-mono text-xs text-mute-2">{r.date}</span>
              <span class="font-mono text-[10px] uppercase tracking-wider px-1.5 py-0.5 rounded bg-brand/10 border border-brand/30 text-brand">
                {r.tag}
              </span>
            </div>
            <ul class="space-y-2 mt-4">
              {r.items.map((item) => (
                <li class="flex items-start gap-2 text-sm text-mute leading-relaxed">
                  <span class="text-brand mt-1.5 flex-shrink-0">·</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </article>
        ))
      }

      <div class="relative pl-8 border-l border-line border-dashed">
        <span class="absolute -left-[5px] top-2 w-2 h-2 rounded-full bg-mute-3 border border-line"></span>
        <p class="text-sm text-mute-2 font-mono">More releases incoming…</p>
      </div>
    </div>
  </section>
</BaseLayout>
