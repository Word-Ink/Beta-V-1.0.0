---
import BaseLayout from "../layouts/BaseLayout.astro";
import CodeBlock from "../components/CodeBlock.astro";
import EditorMockup from "../components/EditorMockup.astro";

const accentSwatches = [
  { name: "Cyan", value: "#22d3ee", deep: "#0891b2", soft: "#67e8f9" },
  { name: "Green", value: "#34d399", deep: "#059669", soft: "#6ee7b7" },
  { name: "Purple", value: "#a78bfa", deep: "#7c3aed", soft: "#c4b5fd" },
  { name: "Amber", value: "#f59e0b", deep: "#d97706", soft: "#fcd34d" },
  { name: "Pink", value: "#ec4899", deep: "#db2777", soft: "#f9a8d4" },
];

// Each item is a piece of text styled as the format it represents.
// Inline HTML allowed via set:html on the wrapper.
const formatItems = [
  { html: "Bold.", class: "format-bold" },
  { html: "Italic.", class: "format-italic" },
  { html: "Underlined.", class: "format-underline" },
  { html: "Strikethrough.", class: "format-strike" },
  { html: "Inline code.", class: "format-code" },
  { html: "Colored.", class: "format-color" },
  { html: "Highlighted.", class: "format-highlight" },
  { html: "A heading.", class: "format-heading" },
  { html: "Subheading.", class: "format-h2" },
  { html: 'H<sub>2</sub>O', class: "format-mono" },
  { html: 'E = mc<sup>2</sup>', class: "format-mono" },
  { html: "Linked.", class: "format-link" },
  { html: '&ldquo;Quoted.&rdquo;', class: "format-quote" },
  { html: "&bull;&nbsp;&nbsp;Bulleted.", class: "" },
  { html: "1.&nbsp;&nbsp;Numbered.", class: "" },
  { html: "All caps.", class: "format-caps" },
  { html: "S P A C E D.", class: "format-wide" },
  { html: "Tight.", class: "format-tight" },
  { html: "&para; Paragraph.", class: "format-dim" },
  { html: "&sect; Section.", class: "format-dim" },
  { html: "&mdash; em-dash.", class: "" },
  { html: "&hellip; ellipsis.", class: "format-dim" },
  { html: "&rarr; arrow.", class: "format-color" },
  { html: "&dagger; footnote.", class: "format-dim" },
];

const capabilities = [
  {
    num: "01",
    title: "Text",
    description: "Every inline mark from Word and Docs.",
    items: [
      { name: "Bold · Italic · Underline · Strike", shipped: true },
      { name: "Inline code", shipped: true },
      { name: "Subscript · Superscript", shipped: true },
      { name: "Font family · Font size", shipped: true },
      { name: "Text color · Highlight", shipped: true },
      { name: "Letter spacing · Line height", shipped: false },
    ],
  },
  {
    num: "02",
    title: "Blocks",
    description: "Headings, lists, quotes, code blocks.",
    items: [
      { name: "Paragraph · Heading 1 → 6", shipped: true },
      { name: "Blockquote · Code block", shipped: true },
      { name: "Bullet · Numbered list", shipped: true },
      { name: "Indentation · Alignment", shipped: true },
      { name: "Horizontal rule", shipped: true },
      { name: "Checklist · Page break", shipped: false },
    ],
  },
  {
    num: "03",
    title: "Insert",
    description: "Anything you can put in a document.",
    items: [
      { name: "Link with popover (⌘K)", shipped: true },
      { name: "Image · URL, paste, drag-and-drop", shipped: true },
      { name: "Horizontal rule · Divider", shipped: true },
      { name: "Tables · row, column, merge", shipped: false },
      { name: "Math · LaTeX (KaTeX)", shipped: false },
      { name: "Mentions · Emoji · Embeds", shipped: false },
    ],
  },
  {
    num: "04",
    title: "Document",
    description: "Long-form scaffolding.",
    items: [
      { name: "Word and character count (live)", shipped: true },
      { name: "Copy HTML · Download HTML · Print to PDF", shipped: true },
      { name: "Fullscreen writing mode", shipped: true },
      { name: "Table of contents (auto)", shipped: false },
      { name: "Footnotes · Page numbers", shipped: false },
      { name: "Autosave · Outline view", shipped: false },
    ],
  },
  {
    num: "05",
    title: "Collaboration",
    description: "Built for a team.",
    items: [
      { name: "Comments (margin)", shipped: false },
      { name: "Suggestions · Track changes", shipped: false },
      { name: "Version history", shipped: false },
      { name: "Real-time co-editing", shipped: false },
      { name: "Live cursors · Presence", shipped: false },
      { name: "Mentions in comments", shipped: false },
    ],
  },
  {
    num: "06",
    title: "Workflow",
    description: "The shortcuts power users want.",
    items: [
      { name: "Undo / Redo · Full history", shipped: true },
      { name: "Keyboard shortcuts (⌘B, ⌘K, …)", shipped: true },
      { name: "Markdown shortcuts (**, *, #, -, >)", shipped: true },
      { name: "Paste-as-plain-text by default", shipped: true },
      { name: "Slash menu (/) for blocks", shipped: false },
      { name: "Find & replace · Bubble menu", shipped: false },
    ],
  },
];

const apiExample = `import { useState } from "react";
import { useEditor, Editor, Toolbar } from "@/components/editor";

export function PostEditor() {
  const [html, setHtml] = useState("");
  const editor = useEditor({ value: html, onChange: setHtml });

  return (
    <Editor instance={editor}>
      <Toolbar>
        <Toolbar.Group>
          <Toolbar.Button cmd="bold" />
          <Toolbar.Button cmd="italic" />
          <Toolbar.Button cmd="underline" />
        </Toolbar.Group>
        <Toolbar.Separator />
        <Toolbar.Dropdown cmd="fontSize" options={SIZES} />
        <Toolbar.ColorPicker cmd="foreColor" />
      </Toolbar>
      <Editor.Content />
      <Editor.Footer>
        {({ words }) => <span>{words} words</span>}
      </Editor.Footer>
    </Editor>
  );
}`;

const comparison = [
  {
    feature: "Cost",
    wordink: { value: "Free · MIT", strong: true },
    docs: { value: "Free w/ Google" },
    word: { value: "$70 / yr" },
    others: { value: "Free (libraries)" },
  },
  {
    feature: "Where it runs",
    wordink: { value: "Your codebase", strong: true },
    docs: { value: "Google's servers" },
    word: { value: "Desktop · web" },
    others: { value: "Your codebase (as dep)" },
  },
  {
    feature: "Source ownership",
    wordink: { value: "Yours", strong: true },
    docs: { value: "Google" },
    word: { value: "Microsoft" },
    others: { value: "Their maintainers" },
  },
  {
    feature: "Customise UI",
    wordink: { value: "Fully · source-level", strong: true },
    docs: { value: "No" },
    word: { value: "No" },
    others: { value: "Extension API" },
  },
  {
    feature: "Headless",
    wordink: { value: "Yes", strong: true },
    docs: { value: "No" },
    word: { value: "No" },
    others: { value: "Some" },
  },
  {
    feature: "Self-host",
    wordink: { value: "Just deploy your app", strong: true },
    docs: { value: "No" },
    word: { value: "On-prem licenses" },
    others: { value: "Yes" },
  },
  {
    feature: "Output",
    wordink: { value: "Plain HTML", strong: true },
    docs: { value: "Proprietary" },
    word: { value: "DOCX (OOXML)" },
    others: { value: "JSON / Delta / HTML" },
  },
];

const plugins = [
  { name: "Link", desc: "Inline popover. Edit, remove, new-tab toggle.", status: "shipped" },
  { name: "Image", desc: "URL paste today. Upload + resize next.", status: "shipped" },
  { name: "Color", desc: "Photoshop-style picker, HSV + hex + swatches.", status: "shipped" },
  { name: "Format", desc: "Bold, italic, underline, strike, code, sub/sup.", status: "shipped" },
  { name: "Lists", desc: "Bullet, numbered, indentation, alignment.", status: "shipped" },
  { name: "Blocks", desc: "Headings 1–6, blockquote, code block, divider.", status: "shipped" },
  { name: "Tables", desc: "Insert. Add rows/cols. Merge cells.", status: "soon" },
  { name: "Slash menu", desc: "Type / to insert any block, Notion-style.", status: "soon" },
  { name: "Bubble menu", desc: "Selection-anchored formatting popup.", status: "soon" },
  { name: "Mentions", desc: "@-tag people, pages, anything.", status: "soon" },
  { name: "Math", desc: "Inline and block LaTeX via KaTeX.", status: "soon" },
  { name: "Comments", desc: "Margin comments, threads, resolution.", status: "soon" },
  { name: "Track changes", desc: "Suggestions mode for review workflows.", status: "soon" },
  { name: "Version history", desc: "Time-travel. Compare. Restore.", status: "soon" },
  { name: "Export", desc: "DOCX, PDF, Markdown, HTML.", status: "soon" },
];

const roadmap = [
  { quarter: "Q2 2026", title: "v0.1 · Foundation", items: ["Core editor", "Headless toolbar", "Theming", "Link · Image · Color"] },
  { quarter: "Q3 2026", title: "v0.2 · Power user", items: ["Tables", "Slash menu", "Bubble menu", "Find & replace"] },
  { quarter: "Q4 2026", title: "v0.3 · Long-form", items: ["TOC", "Footnotes", "Headers/footers", "Page numbers"] },
  { quarter: "Q1 2027", title: "v0.4 · Collaboration", items: ["Comments", "Track changes", "Version history", "Live cursors"] },
];
---

<BaseLayout>
  <!-- HERO -->
  <section
    class="relative overflow-hidden min-h-[calc(100vh-3.5rem)] flex items-center"
  >
    <div class="hero-grid"></div>

    <!-- Floating format words — single safe column on the right.
         Each one demonstrates its own format and reacts on hover. -->
    <div class="hero-floats" aria-hidden="true">
      <span class="hero-float format-bold" data-syntax="**bold**" style="top: 5%; right: 14%; --r: -4deg; --delay: 0s; --dur: 7.6s;">Bold.</span>
      <span class="hero-float format-italic" data-syntax="*italic*" style="top: 18%; right: 8%; --r: 6deg; --delay: 1.4s; --dur: 8.4s;">Italic.</span>
      <span class="hero-float format-code" data-syntax="`code`" style="top: 31%; right: 14%; --r: -2deg; --delay: 0.6s; --dur: 9s;" set:html="{ code }"></span>
      <span class="hero-float format-heading" data-syntax="# Heading" style="top: 43%; right: 4%; --r: 3deg; --delay: 2s; --dur: 8.2s;">Heading.</span>
      <span class="hero-float format-highlight" data-syntax="==highlight==" style="top: 56%; right: 6%; --r: -5deg; --delay: 0.9s; --dur: 7.4s;">Highlight.</span>
      <span class="hero-float format-quote" data-syntax="> quote" style="top: 69%; right: 10%; --r: 4deg; --delay: 1.7s; --dur: 8.8s;">&ldquo;Quote.&rdquo;</span>
      <span class="hero-float format-link" data-syntax="[link](url)" style="top: 82%; right: 12%; --r: 2deg; --delay: 0.4s; --dur: 9.2s;">Linked.</span>
      <span class="hero-float format-strike" data-syntax="~~strike~~" style="bottom: 4%; right: 4%; --r: -3deg; --delay: 1.5s; --dur: 8.6s;">Strikethrough.</span>
    </div>

    <div class="relative w-full max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 py-12 md:py-16">
      <div class="max-w-4xl">
        <div
          class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand/10 border border-brand/30 text-brand text-xs font-mono fade-up"
          style="animation-delay: 0ms;"
        >
          <span
            class="w-1.5 h-1.5 rounded-full bg-brand shadow-[0_0_10px_currentColor]"
          ></span>
          v0.1.0 · early access · the open Google Docs
        </div>

        <h1
          class="mt-6 text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-semibold tracking-tighter leading-[0.98] fade-up"
          style="animation-delay: 80ms;"
        >
          The <span
            class="typewriter-wrap"
            ><span
              data-typewriter
              data-words="text,document,rich text,Markdown,block,WYSIWYG"
              >text</span
            ><span class="typewriter-cursor" aria-hidden="true"></span></span
          > editor<br />
          <span class="text-mute">you copy into</span><br />
          <span class="bg-gradient-to-r from-brand via-brand-soft to-brand bg-clip-text text-transparent">your codebase.</span>
        </h1>

        <p
          class="mt-8 text-lg md:text-xl text-mute max-w-2xl leading-relaxed fade-up"
          style="animation-delay: 180ms;"
        >
          Everything Google Docs and Microsoft Word can do — formatting, tables,
          comments, version history — but the source lives in <em
            class="text-ink not-italic">your repo</em
          >, not your dependency tree.
        </p>

        <div
          class="mt-9 flex items-center gap-3 flex-wrap fade-up"
          style="animation-delay: 280ms;"
        >
          <a
            href="/docs"
            class="cta-glow group inline-flex items-center gap-2 bg-brand text-bg font-semibold px-5 py-3 rounded-md text-sm"
          >
            Get started
            <span class="transition-transform group-hover:translate-x-0.5">→</span>
          </a>
          <a
            href="/playground"
            class="inline-flex items-center gap-2 border border-line-2 text-ink px-5 py-3 rounded-md text-sm hover:bg-surface transition-colors"
          >
            Try the playground
          </a>
          <a
            href="https://github.com/Word-Ink/Beta-V-1.0.0"
            target="_blank"
            rel="noopener"
            class="ml-1 inline-flex items-center gap-2 text-mute hover:text-ink px-3 py-3 rounded-md text-sm transition-colors"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
              ></path>
            </svg>
            GitHub
          </a>
        </div>

        <div
          class="mt-7 inline-flex items-center gap-3 bg-surface border border-line rounded-md px-4 py-2.5 font-mono text-sm fade-up"
          style="animation-delay: 380ms;"
        >
          <span class="text-brand select-none">$</span>
          <code>
            <span class="text-ink">npx wordink add</span>
            <span class="text-brand">editor</span>
          </code>
          <button
            class="ml-1 text-mute-2 hover:text-ink transition-colors"
            data-copy-install
            aria-label="Copy install command"
          >
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <rect x="9" y="9" width="13" height="13" rx="2" />
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
            </svg>
          </button>
        </div>

        <!-- Interactive accent picker — retheme the site live -->
        <div
          class="mt-7 flex items-center gap-4 flex-wrap fade-up"
          style="animation-delay: 480ms;"
        >
          <span class="text-[11px] font-mono uppercase tracking-[0.14em] text-mute-2">
            Click to retheme &rarr;
          </span>
          <div class="flex items-center gap-2" role="radiogroup" aria-label="Accent color">
            {
              accentSwatches.map((s) => (
                <button
                  type="button"
                  data-set-accent={JSON.stringify(s)}
                  data-accent-name={s.name}
                  title={`${s.name} — apply site-wide`}
                  aria-label={s.name}
                  class="w-7 h-7 rounded-full hover:scale-110 transition-transform relative ring-offset-2 ring-offset-bg"
                  style={`background: ${s.value}`}
                />
              ))
            }
            <button
              type="button"
              data-reset-accent
              title="Reset to default"
              aria-label="Reset accent"
              class="ml-1 text-xs font-mono text-mute-2 hover:text-ink transition-colors flex items-center gap-1"
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
                <path d="M3 3v5h5"/>
              </svg>
              Reset
            </button>
          </div>
        </div>
        <p class="mt-2 text-xs text-mute-3 font-mono">
          (Every <code class="text-mute-2">--color-brand</code> on the page updates instantly.)
        </p>
      </div>
    </div>
  </section>

  <!-- EDITOR PREVIEW + GATEWAY TO PLAYGROUND -->
  <section class="relative">
    <div
      class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 pb-20 md:pb-28 fade-up"
    >
      <div class="mb-6 flex items-end justify-between gap-4 flex-wrap">
        <div>
          <p class="font-mono text-xs uppercase tracking-[0.14em] text-mute mb-2">
            What it looks like
          </p>
          <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">
            A taste, in still frame.
          </h2>
        </div>
        <a
          href="/playground"
          class="group inline-flex items-center gap-2 cta-glow bg-brand text-bg font-semibold px-5 py-2.5 rounded-md text-sm"
        >
          Try the live editor
          <span class="transition-transform group-hover:translate-x-0.5">→</span>
        </a>
      </div>
      <EditorMockup />
      <p class="mt-6 text-center text-sm text-mute-2 font-mono">
        Static preview. Hop to the
        <a href="/playground" class="text-brand underline decoration-brand/40 underline-offset-4 hover:decoration-brand">playground</a>
        for the real thing — fully interactive, in your browser.
      </p>
    </div>
  </section>

  <!-- API SHOWCASE -->
  <section class="relative border-t border-line">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div>
          <p class="font-mono text-xs uppercase tracking-[0.14em] text-mute mb-3">
            The API
          </p>
          <h2 class="text-3xl md:text-4xl font-semibold tracking-tight mb-5 leading-tight">
            One hook. <br class="hidden md:block" />Every command.
          </h2>
          <p class="text-mute leading-relaxed mb-4 text-lg max-w-lg">
            <code class="text-ink bg-surface border border-line px-1.5 py-0.5 rounded text-base font-mono">useEditor</code>
            returns an instance you pass to <code class="text-ink bg-surface border border-line px-1.5 py-0.5 rounded text-base font-mono">&lt;Editor&gt;</code>.
            Drop the toolbar primitives in — Shadcn, Radix, your own — or
            skip them and call commands directly.
          </p>
          <p class="text-mute leading-relaxed text-lg max-w-lg">
            No wrapper components. No prescribed styling. The editor
            doesn't care.
          </p>
          <div class="mt-7 flex items-center gap-3 flex-wrap">
            <a
              href="/docs/editor"
              class="inline-flex items-center gap-2 text-sm text-brand hover:underline underline-offset-4"
            >
              Editor API reference →
            </a>
            <a
              href="/docs/toolbar"
              class="inline-flex items-center gap-2 text-sm text-mute hover:text-ink transition-colors"
            >
              Toolbar primitives →
            </a>
          </div>
        </div>

        <CodeBlock code={apiExample} lang="tsx" filename="post-editor.tsx" showDots />
      </div>
    </div>
  </section>

  <!-- CAPABILITIES -->
  <section class="relative border-t border-line">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="mb-14 max-w-3xl">
        <p class="font-mono text-xs uppercase tracking-[0.14em] text-mute mb-3">
          Capabilities
        </p>
        <h2 class="text-3xl md:text-5xl font-semibold tracking-tight mb-5 leading-tight">
          A complete document editor. <span class="text-mute">Not a stripped-down toy.</span>
        </h2>
        <p class="text-lg text-mute leading-relaxed">
          Six categories. Sixty-plus features. We're aiming for Word and
          Google Docs parity, not just rich text basics. Shipped today is
          marked clearly; the rest is in active development.
        </p>
      </div>

      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-line border border-line rounded-xl overflow-hidden"
      >
        {
          capabilities.map((cat) => {
            const shippedCount = cat.items.filter((i) => i.shipped).length;
            return (
              <div class="bg-bg p-7 hover:bg-surface/30 transition-colors">
                <div class="flex items-center justify-between mb-5">
                  <span class="font-mono text-xs text-brand">{cat.num}</span>
                  <span class="font-mono text-[10px] uppercase tracking-wider text-mute-2">
                    {shippedCount} / {cat.items.length} shipped
                  </span>
                </div>
                <h3 class="text-xl font-semibold mb-2 tracking-tight">{cat.title}</h3>
                <p class="text-sm text-mute-2 mb-5 leading-relaxed">{cat.description}</p>
                <ul class="space-y-2">
                  {cat.items.map((item) => (
                    <li class="flex items-start gap-2 text-[13px] leading-relaxed">
                      {item.shipped ? (
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-brand mt-0.5 flex-shrink-0">
                          <path d="M20 6 9 17l-5-5" />
                        </svg>
                      ) : (
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-mute-3 mt-0.5 flex-shrink-0">
                          <circle cx="12" cy="12" r="9" />
                        </svg>
                      )}
                      <span class={item.shipped ? "text-ink" : "text-mute-2"}>
                        {item.name}
                      </span>
                    </li>
                  ))}
                </ul>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- PLUGINS GRID -->
  <section class="relative border-t border-line">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="mb-14 max-w-3xl">
        <p class="font-mono text-xs uppercase tracking-[0.14em] text-mute mb-3">
          Plugins
        </p>
        <h2 class="text-3xl md:text-5xl font-semibold tracking-tight mb-5 leading-tight">
          Everything an editor needs.
        </h2>
        <p class="text-lg text-mute leading-relaxed">
          Each plugin is a single file. Add the ones you use to the
          toolbar; ignore the rest. Or write your own — the API is small
          enough to read in an afternoon.
        </p>
      </div>

      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-line border border-line rounded-xl overflow-hidden"
      >
        {
          plugins.map(({ name, desc, status }) => (
            <div class="bg-bg p-6 hover:bg-surface/30 transition-colors">
              <div class="flex items-center gap-2 mb-2">
                <h3 class="font-semibold">{name}</h3>
                {status === "shipped" ? (
                  <span class="font-mono text-[10px] uppercase tracking-wider px-1.5 py-0.5 rounded bg-brand/10 border border-brand/30 text-brand">
                    Shipped
                  </span>
                ) : (
                  <span class="font-mono text-[10px] uppercase tracking-wider px-1.5 py-0.5 rounded bg-surface-2 border border-line text-mute-2">
                    Soon
                  </span>
                )}
              </div>
              <p class="text-sm text-mute leading-relaxed">{desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- COMPARISON -->
  <section class="relative border-t border-line">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="mb-14 max-w-3xl">
        <p class="font-mono text-xs uppercase tracking-[0.14em] text-mute mb-3">
          How it compares
        </p>
        <h2 class="text-3xl md:text-5xl font-semibold tracking-tight mb-5 leading-tight">
          A different shape of solution.
        </h2>
        <p class="text-lg text-mute leading-relaxed">
          Tiptap and Lexical are excellent editor libraries — but they're
          dependencies. Google Docs and Word are excellent products — but
          you don't own them. wordink is a third option.
        </p>
      </div>

      <div class="border border-line rounded-xl overflow-hidden overflow-x-auto bg-bg">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-line bg-surface/40">
              <th class="text-left p-4 font-mono text-[10px] uppercase tracking-[0.14em] text-mute font-medium"></th>
              <th class="text-left p-4 font-mono text-[10px] uppercase tracking-[0.14em] text-brand font-semibold border-l border-line">
                wordink
              </th>
              <th class="text-left p-4 font-mono text-[10px] uppercase tracking-[0.14em] text-mute font-medium border-l border-line">
                Google Docs
              </th>
              <th class="text-left p-4 font-mono text-[10px] uppercase tracking-[0.14em] text-mute font-medium border-l border-line">
                MS Word
              </th>
              <th class="text-left p-4 font-mono text-[10px] uppercase tracking-[0.14em] text-mute font-medium border-l border-line">
                Tiptap / Lexical
              </th>
            </tr>
          </thead>
          <tbody>
            {
              comparison.map((row, i) => (
                <tr
                  class:list={[
                    "border-b border-line last:border-b-0",
                    i % 2 === 1 && "bg-surface/20",
                  ]}
                >
                  <td class="p-4 font-medium text-ink">{row.feature}</td>
                  <td class="p-4 border-l border-line">
                    <span class:list={["text-ink", row.wordink.strong && "font-medium"]}>
                      {row.wordink.value}
                    </span>
                  </td>
                  <td class="p-4 text-mute border-l border-line">{row.docs.value}</td>
                  <td class="p-4 text-mute border-l border-line">{row.word.value}</td>
                  <td class="p-4 text-mute border-l border-line">{row.others.value}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-xs text-mute-2 font-mono">
        Comparison reflects each product / library's documented behaviour as of 2026.
      </p>
    </div>
  </section>

  <!-- ROADMAP -->
  <section class="relative border-t border-line">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="mb-14 max-w-3xl">
        <p class="font-mono text-xs uppercase tracking-[0.14em] text-mute mb-3">
          Roadmap
        </p>
        <h2 class="text-3xl md:text-5xl font-semibold tracking-tight mb-5 leading-tight">
          The path to parity.
        </h2>
        <p class="text-lg text-mute leading-relaxed">
          Four releases between here and feature parity with Google Docs.
          We're building in the open — every release ships to GitHub the
          day it's tagged.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-line border border-line rounded-xl overflow-hidden">
        {
          roadmap.map((r, i) => (
            <div class:list={["bg-bg p-7 relative", i === 0 && "bg-gradient-to-b from-brand/5 to-bg"]}>
              <p class="font-mono text-xs text-brand mb-1">{r.quarter}</p>
              <h3 class="text-lg font-semibold mb-4">{r.title}</h3>
              <ul class="space-y-2">
                {r.items.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-mute leading-relaxed">
                    <span class="text-mute-2 mt-1.5 flex-shrink-0">·</span>
                    {item}
                  </li>
                ))}
              </ul>
              {i === 0 && (
                <span class="absolute top-3 right-3 font-mono text-[10px] uppercase tracking-wider px-1.5 py-0.5 rounded bg-brand/10 border border-brand/30 text-brand">
                  Active
                </span>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- FOOTER CTA -->
  <section class="relative border-t border-line">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 py-20 md:py-28">
      <div
        class="border border-line rounded-2xl bg-gradient-to-b from-surface/60 to-bg p-10 md:p-16 text-center relative overflow-hidden"
      >
        <div
          class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(34,211,238,0.12),transparent_60%)] pointer-events-none"
        ></div>
        <div class="relative">
          <h2
            class="text-3xl md:text-5xl lg:text-6xl font-semibold tracking-tight mb-5 leading-tight"
          >
            Stop fighting your editor.
          </h2>
          <p class="text-mute mb-9 max-w-xl mx-auto leading-relaxed text-lg">
            Copy the source. Style it your way. Ship the document editor your
            users deserve.
          </p>
          <div class="flex items-center justify-center gap-3 flex-wrap">
            <a
              href="/docs"
              class="cta-glow group inline-flex items-center gap-2 bg-brand text-bg font-semibold px-5 py-3 rounded-md text-sm"
            >
              Read the docs
              <span class="transition-transform group-hover:translate-x-0.5">→</span>
            </a>
            <a
              href="https://github.com/Word-Ink/Beta-V-1.0.0"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 border border-line-2 text-ink px-5 py-3 rounded-md text-sm hover:bg-surface transition-colors"
            >
              Star on GitHub
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // ── Copy install command ──
  document
    .querySelector("[data-copy-install]")
    ?.addEventListener("click", async (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      try {
        await navigator.clipboard.writeText("npx wordink add editor");
        const orig = btn.innerHTML;
        btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M20 6 9 17l-5-5"/></svg>`;
        btn.classList.add("text-brand");
        setTimeout(() => {
          btn.innerHTML = orig;
          btn.classList.remove("text-brand");
        }, 1500);
      } catch {}
    });

  // ── Typewriter on the headline first word ──
  const tw = document.querySelector(
    "[data-typewriter]",
  ) as HTMLElement | null;
  if (tw) {
    // Clear any timer left over from a previous (HMR) run.
    if ((window as any).__wordinkTwTimer) {
      clearTimeout((window as any).__wordinkTwTimer);
    }
    const words = (tw.dataset.words || "text")
      .split(",")
      .map((w) => w.trim())
      .filter(Boolean);
    let wordIdx = 0;
    let charIdx = words[0].length;
    let deleting = false;

    tw.textContent = words[0];

    function step() {
      const current = words[wordIdx];
      if (deleting) {
        charIdx--;
        tw!.textContent = current.slice(0, charIdx);
        if (charIdx <= 0) {
          deleting = false;
          wordIdx = (wordIdx + 1) % words.length;
          (window as any).__wordinkTwTimer = setTimeout(step, 340);
          return;
        }
        (window as any).__wordinkTwTimer = setTimeout(step, 45);
      } else {
        charIdx++;
        tw!.textContent = current.slice(0, charIdx);
        if (charIdx >= current.length) {
          deleting = true;
          (window as any).__wordinkTwTimer = setTimeout(step, 1900);
          return;
        }
        (window as any).__wordinkTwTimer = setTimeout(step, 95);
      }
    }
    // Hold on the first word a moment, then start the cycle.
    (window as any).__wordinkTwTimer = setTimeout(() => {
      deleting = true;
      (window as any).__wordinkTwTimer = setTimeout(step, 1700);
    }, 2400);
  }

  // ── Interactive accent picker ──
  const ACCENT_KEY = "wordink:accent";
  const DEFAULT_ACCENT = { value: "#22d3ee", deep: "#0891b2", soft: "#67e8f9", name: "Cyan" };

  function applyAccent(a: { value: string; deep: string; soft: string; name?: string }) {
    const root = document.documentElement;
    root.style.setProperty("--color-brand", a.value);
    root.style.setProperty("--color-brand-deep", a.deep);
    root.style.setProperty("--color-brand-soft", a.soft);
    // Mark active swatch
    document.querySelectorAll("[data-set-accent]").forEach((b) => {
      const el = b as HTMLElement;
      const data = JSON.parse(el.getAttribute("data-set-accent") || "{}");
      const active = data.value === a.value;
      el.classList.toggle("ring-2", active);
      el.classList.toggle("ring-ink", active);
    });
  }

  function loadSavedAccent() {
    try {
      const raw = localStorage.getItem(ACCENT_KEY);
      if (raw) return JSON.parse(raw);
    } catch {}
    return null;
  }

  // Init: apply saved or default
  applyAccent(loadSavedAccent() || DEFAULT_ACCENT);

  document.querySelectorAll("[data-set-accent]").forEach((btn) => {
    btn.addEventListener("click", () => {
      try {
        const data = JSON.parse(btn.getAttribute("data-set-accent") || "{}");
        applyAccent(data);
        localStorage.setItem(ACCENT_KEY, JSON.stringify(data));
      } catch {}
    });
  });

  document.querySelector("[data-reset-accent]")?.addEventListener("click", () => {
    localStorage.removeItem(ACCENT_KEY);
    applyAccent(DEFAULT_ACCENT);
  });
</script>
